# --- Cách 1: Gọi thẳng BE (CORS phải mở cho origin FE) ---
# VITE_API_BASE_URL=http://localhost:5276

# --- Cách 2: Dev — để trống + dùng proxy Vite (vite.config.js → /api → BE) ---
VITE_API_BASE_URL=

# Tuỳ chọn: đổi port BE khi dev
# VITE_DEV_PROXY_TARGET=http://localhost:5276

# --- Docker (VPS): truyền khi build, ví dụ docker compose / docker build --build-arg ---
# VITE_API_BASE_URL=https://api.example.com
# FE_PORT=8080
