@model MacVilla_Web.Models.CartItemDto

<div class="cart-item" id="cart-item-@Model.CartItemId">
    <div class="row align-items-center">
        <div class="col-3 col-md-2">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" alt="@Model.ProductName" class="img-fluid rounded" style="max-height: 80px; object-fit: cover;">
            }
            else
            {
                <div class="img-fluid rounded bg-light d-flex align-items-center justify-content-center" style="max-height: 80px;">
                    <i class="fas fa-box text-muted"></i>
                </div>
            }
        </div>
        <div class="col-9 col-md-4">
            <h6 class="mb-1">@Model.ProductName</h6>
            <p class="text-muted mb-0 small">@Model.UnitPrice.ToString("N0") ₫</p>
        </div>
        <div class="col-6 col-md-3 mt-2 mt-md-0">
            <div class="input-group input-group-sm" style="max-width: 120px;">
                <button class="btn btn-outline-secondary" onclick="updateQuantity(@Model.CartItemId, @Model.Quantity - 1)">
                    <i class="fas fa-minus"></i>
                </button>
                <input type="number" class="form-control text-center" value="@Model.Quantity" 
                       min="1" onchange="updateQuantity(@Model.CartItemId, this.value)">
                <button class="btn btn-outline-secondary" onclick="updateQuantity(@Model.CartItemId, @Model.Quantity + 1)">
                    <i class="fas fa-plus"></i>
                </button>
            </div>
        </div>
        <div class="col-4 col-md-2 mt-2 mt-md-0 text-end">
            <strong>@Model.SubTotal.ToString("N0") ₫</strong>
        </div>
        <div class="col-2 col-md-1 mt-2 mt-md-0 text-end">
            <button class="btn btn-sm btn-outline-danger" onclick="deleteCartItem(@Model.CartItemId)">
                <i class="fas fa-trash"></i>
            </button>
        </div>
    </div>
</div>
