@{
    Layout = null;
    var page = ViewContext.RouteData.Values["page"]?.ToString()?.ToLower() ?? string.Empty;

    bool IsActive(string prefix)
    {
        return page.StartsWith(prefix.ToLower());
    }
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MacVilla Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

    <style>
        :root {
            --mv-green-dark: #7DA100;
            --mv-green-light: #f9fff0;
            --mv-green-border: #e2f0d1;
            --sidebar-width: 260px;
        }

        body {
            background-color: #f4f6f9;
            font-family: 'Segoe UI', Tahoma, sans-serif;
            margin: 0;
        }

        .admin-header {
            background-color: var(--mv-green-dark);
            height: 65px;
            position: fixed;
            width: 100%;
            top: 0;
            z-index: 1050;
            padding: 0 30px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        .admin-sidebar {
            width: var(--sidebar-width);
            height: 100vh;
            position: fixed;
            top: 65px;
            left: 0;
            background: white;
            z-index: 1000;
            padding-top: 10px;
            border-right: 1px solid #eee;
        }

        .nav-link-custom {
            display: flex;
            align-items: center;
            padding: 12px 25px;
            color: #444;
            text-decoration: none;
            transition: 0.2s;
            font-size: 0.95rem;
            font-weight: 500;
        }

            .nav-link-custom i {
                margin-right: 15px;
                font-size: 1.2rem;
                color: var(--mv-green-dark);
            }

            .nav-link-custom:hover {
                background-color: var(--mv-green-light);
                color: var(--mv-green-dark);
            }

            .nav-link-custom.active {
                background-color: var(--mv-green-dark) !important;
                color: #ffffff !important;
            }

        .admin-wrapper {
            margin-top: 65px;
            margin-left: var(--sidebar-width);
            padding: 40px;
            min-height: calc(100vh - 115px);
        }

        .admin-footer {
            background-color: var(--mv-green-dark);
            color: #ffffff;
            padding: 15px 40px;
            font-size: 13px;
            margin-left: var(--sidebar-width);
        }
    </style>

    @RenderSection("Styles", required: false)
</head>
<body>
    <header class="admin-header d-flex align-items-center justify-content-between">
        <div class="d-flex align-items-center">
            <img src="~/Image/Logo/logo-macvilla.png" alt="MacVilla" style="height: 35px;" class="me-3" />
            <span class="text-white fw-bold border-start ps-3 small text-uppercase">Quản lý hệ thống</span>
        </div>
        <div class="dropdown">
            <button class="btn btn-link text-white text-decoration-none dropdown-toggle small" data-bs-toggle="dropdown">
                <i class="bi bi-person-circle me-1"></i> Admin MacVilla
            </button>
            <ul class="dropdown-menu dropdown-menu-end border-0 shadow">
                <li>
                    <a class="dropdown-item py-2" href="/Admin/Dashboard">
                        <i class="bi bi-speedometer2 me-2"></i> Dashboard
                    </a>
                </li>
                <li><hr class="dropdown-divider" /></li>
                <li>
                    <a class="dropdown-item py-2 text-danger" asp-page="/Auth/Logout">
                        <i class="bi bi-box-arrow-right me-2"></i> Đăng xuất
                    </a>
                </li>
            </ul>
        </div>
    </header>

    <aside class="admin-sidebar shadow-sm">
        <div class="px-4 py-3 small text-muted text-uppercase fw-bold" style="font-size: 0.7rem;">Menu chính</div>
        <nav>
            <a asp-page="/Admin/Dashboard/Index" class="nav-link-custom @(IsActive("/admin/dashboard/index") ? "active" : string.Empty)">
                <i class="bi bi-speedometer2"></i> Tổng quan
            </a>
            <a asp-page="/Admin/Products/Index" class="nav-link-custom @(IsActive("/admin/products/index") ? "active" : string.Empty)">
                <i class="bi bi-box-seam"></i> Quản lý Sản phẩm
            </a>
            <a asp-page="/Admin/Categories/Index" class="nav-link-custom @(IsActive("/admin/categories/index") ? "active" : string.Empty)">
                <i class="bi bi-tags"></i> Quản lý Danh Mục
            </a>
            <a asp-page="/Admin/Orders/Index" class="nav-link-custom @(IsActive("/admin/orders/index") ? "active" : string.Empty)">
                <i class="bi bi-receipt"></i> Quản lý Đơn hàng
            </a>
            <a asp-page="/Admin/Inventory/Index" class="nav-link-custom @(IsActive("/admin/inventory/index") ? "active" : string.Empty)">
                <i class="bi bi-clipboard-data"></i> Quản lý Tồn kho
            </a>
            <a asp-page="/Admin/UserManager/Index" class="nav-link-custom @(IsActive("/admin/usermanager/index") ? "active" : string.Empty)">
                <i class="bi bi-people"></i> Quản lý người dùng
            </a>
        </nav>
    </aside>

    <main class="admin-wrapper">
        @RenderBody()
    </main>

    <footer class="admin-footer d-flex justify-content-between">
        <div>&copy; 2026 <strong>MACVILLA</strong>. CMS.</div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
