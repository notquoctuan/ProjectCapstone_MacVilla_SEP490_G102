@page "{id:long}"
@model DetailsModel

<div class="container mt-4">
    <div class="card shadow border-0">
        <div class="card-header bg-white py-3">
            <h5 class="mb-0">Chi tiết sản phẩm: @Model.Product.Name</h5>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-4">
                    <img src="@Model.Product.DisplayImage" class="img-fluid rounded border" />
                </div>
                <div class="col-md-8">
                    <p><strong>Mã SP:</strong> #@Model.Product.ProductId</p>
                    <p><strong>Giá:</strong> <span class="text-danger fw-bold">@Model.Product.Price.ToString("N0")đ</span></p>
                    <p><strong>Danh mục:</strong> @Model.Product.CategoryName</p>
                    <p><strong>Trạng thái:</strong> @Model.Product.Status</p>
                    <hr />
                    <h6>Mô tả:</h6>
                    <div>@Html.Raw(Model.Product.Description)</div>
                </div>
            </div>
        </div>
        <div class="card-footer bg-light text-end">
            <a asp-page="./Index" class="btn btn-secondary">Quay lại</a>
            <a asp-page="./Edit" asp-route-id="@Model.Product.ProductId" class="btn btn-primary">Chỉnh sửa</a>
        </div>
    </div>
</div>