@page
@model MacVilla_Web.Pages.Cart.IndexModel
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@{
    Layout = null;
    var token = HttpContextAccessor.HttpContext?.Session.GetString("JWToken");
    var isAuthenticated = !string.IsNullOrEmpty(token);
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Giỏ hàng - Macvilla</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />
    <link rel="stylesheet" href="~/css/homepage.css" />
    <style>
        .cart-page-container {
            min-height: 60vh;
            padding: 20px 0;
        }
        .cart-item {
            padding: 15px 0;
            border-bottom: 1px solid #eee;
        }
        .cart-item:last-child {
            border-bottom: none;
        }
        .cart-item img {
            border-radius: 4px;
            object-fit: cover;
            width: 80px;
            height: 80px;
        }
        .quantity-input {
            width: 70px;
            text-align: center;
        }
        .cart-summary {
            position: sticky;
            top: 20px;
        }
        @@media (max-width: 768px) {
            .cart-item .row > div {
                margin-bottom: 10px;
            }
            .cart-item img {
                width: 60px;
                height: 60px;
            }
        }
    </style>
</head>
<body class="homepage-theme">

<!-- ============ TOP BAR ============ -->
<div class="top-bar">
    <div class="container d-flex justify-content-between align-items-center flex-wrap gap-1">
        <div>
            <i class="fas fa-phone-alt me-1"></i>
            <strong>Hotline: 1800 6060</strong>
            <span class="separator d-md-inline"> | </span>
            <a href="#" class="d-md-inline"><i class="fas fa-store me-1"></i>Hệ thống showroom</a>
        </div>
        <div>
            <a href="#"><i class="fas fa-newspaper me-1"></i>Tin tức</a>
            <a href="#"><i class="fas fa-briefcase me-1"></i>Tuyển dụng</a>
            @if (isAuthenticated)
            {
                <a href="/Auth/Logout"><i class="fas fa-sign-out-alt me-1"></i>Đăng xuất</a>
                <a href="/Admin/Dashboard/Index"><i class="fas fa-tachometer-alt me-1"></i>Admin</a>
            }
            else
            {
                <a href="/Auth/Login"><i class="fas fa-user me-1"></i>Đăng nhập</a>
            }
        </div>
    </div>
</div>

<!-- ============ MAIN HEADER ============ -->
<div class="main-header">
    <div class="container">
        <div class="d-flex align-items-center gap-3 flex-wrap">
            <a href="/" class="logo me-2">Macvilla</a>
            <div class="search-bar flex-grow-1">
                <form method="get" action="/">
                    <div class="input-group">
                        <input type="text" class="form-control" placeholder="Tìm kiếm sản phẩm..." name="SearchQuery" />
                        <button type="submit" class="btn btn-warning">
                            <i class="fas fa-search"></i>
                        </button>
                    </div>
                </form>
            </div>
            <button class="region-btn">
                <i class="fas fa-map-marker-alt me-1"></i>Hà Nội
            </button>
            <a href="/Cart" class="cart-btn position-relative text-decoration-none">
                <i class="fas fa-shopping-cart me-1"></i>Giỏ hàng
                <span class="cart-badge" id="cart-badge">0</span>
            </a>
        </div>
    </div>
</div>

<!-- ============ NAV MENU ============ -->
<div class="nav-menu">
    <div class="container">
        <ul class="nav-list">
            <li class="cat-mega-menu-wrapper">
                <a href="/#categories">
                    <i class="fas fa-th-large me-1"></i>Tất cả danh mục
                    <i class="fas fa-chevron-down ms-1" style="font-size:10px;"></i>
                </a>
            </li>
            <li><a href="/">Trang chủ</a></li>
            <li><a href="#">Sản phẩm</a></li>
            <li><a href="#">Liên hệ</a></li>
        </ul>
    </div>
</div>

<!-- ============ MAIN CONTENT ============ -->
<div class="container cart-page-container" style="max-width: 1200px;">
    
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/"><i class="fas fa-home"></i> Trang chủ</a></li>
            <li class="breadcrumb-item active" aria-current="page">Giỏ hàng</li>
        </ol>
    </nav>

    <h2 class="mb-4"><i class="fas fa-shopping-cart me-2"></i>Giỏ hàng của bạn</h2>

    @if (isAuthenticated)
    {
        <div class="row">
            <div class="col-lg-8">
                <div class="card shadow-sm mb-3">
                    <div class="card-body" id="cart-items-container">
                        <div class="text-center py-5">
                            <i class="fas fa-spinner fa-spin fa-3x"></i>
                            <p class="mt-2">Đang tải giỏ hàng...</p>
                        </div>
                    </div>
                </div>
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <a href="/" class="btn btn-outline-primary">
                        <i class="fas fa-arrow-left me-1"></i> Tiếp tục mua sắm
                    </a>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="card shadow-sm cart-summary">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0"><i class="fas fa-receipt me-2"></i>Tổng thanh toán</h5>
                    </div>
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-2">
                            <span>Tạm tính:</span>
                            <span id="cart-subtotal">0 ₫</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span>Giảm giá:</span>
                            <span class="text-success">0 ₫</span>
                        </div>
                        <hr>
                        <div class="d-flex justify-content-between mb-3">
                            <strong>Tổng cộng:</strong>
                            <strong class="text-primary fs-5" id="cart-total">0 ₫</strong>
                        </div>
                        <button class="btn btn-success w-100 btn-lg" onclick="alert('Tính năng đang được phát triển!')">
                            <i class="fas fa-credit-card me-2"></i>Tiến hành thanh toán
                        </button>
                        <p class="text-muted small text-center mt-2 mb-0">
                            <i class="fas fa-shield-alt me-1"></i>Thanh toán an toàn
                        </p>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-body text-center py-5">
                <i class="fas fa-user-lock fa-4x text-muted mb-3"></i>
                <h4>Vui lòng đăng nhập</h4>
                <p class="text-muted">Bạn cần đăng nhập để xem giỏ hàng của mình.</p>
                <a href="/Auth/Login?returnUrl=/Cart" class="btn btn-primary btn-lg">
                    <i class="fas fa-sign-in-alt me-2"></i>Đăng nhập ngay
                </a>
                <p class="mt-3">
                    Chưa có tài khoản? 
                    <a href="/Auth/Register">Đăng ký ngay</a>
                </p>
            </div>
        </div>
    }
</div>

<!-- ============ FOOTER ============ -->
<footer class="footer-main mt-4">
    <div class="container">
        <div class="row g-4">
            <div class="col-12 col-md-4">
                <h5><i class="fas fa-home me-2"></i>Macvilla</h5>
                <p>Hệ thống phân phối thiết bị vệ sinh và nhà bếp hàng đầu Việt Nam.</p>
            </div>
            <div class="col-6 col-md-2">
                <h5>Hỗ Trợ</h5>
                <a href="#">Chính sách đổi trả</a>
                <a href="#">Chính sách bảo hành</a>
            </div>
            <div class="col-6 col-md-2">
                <h5>Hệ Thống</h5>
                <a href="#"><i class="fas fa-store me-1"></i>Hà Nội</a>
                <a href="#"><i class="fas fa-store me-1"></i>TP.HCM</a>
            </div>
            <div class="col-12 col-md-4">
                <h5>Liên Hệ</h5>
                <p><strong>Hotline:</strong> 1800 6060</p>
            </div>
        </div>
    </div>
</footer>
<div class="footer-bottom">
    <div class="container">
        &copy; 2026 Macvilla. Bảo lưu mọi quyền.
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/cart.js"></script>
<script>
    // Load cart data on page load
    document.addEventListener('DOMContentLoaded', function() {
        @if (isAuthenticated)
        {
            <text>
            loadCart();
            </text>
        }
    });
</script>
</body>
</html>
