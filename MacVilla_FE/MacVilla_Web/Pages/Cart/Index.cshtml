@page
@model MacVilla_Web.Pages.Cart.IndexModel
@{
    Layout = null;
    var token = ViewContext.HttpContext.Session.GetString("JWToken") ?? ViewContext.HttpContext.Request.Cookies["jwt"];
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Giỏ hàng - Macvilla</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />
    <link rel="stylesheet" href="~/css/cart.css" />
    <script>
        window.API_BASE_URL = 'https://localhost:7262/';
    </script>
</head>
<body class="cart-page">

    <!-- ============ TOP BAR ============ -->
    <div class="top-bar">
        <div class="container d-flex justify-content-between align-items-center flex-wrap gap-1">
            <div>
                <i class="fas fa-phone-alt me-1"></i>
                <strong>Hotline: 1800 6060</strong>
                <span class="separator d-md-inline"> | </span>
                <a href="#" class="d-md-inline"><i class="fas fa-store me-1"></i>Hệ thống showroom</a>
            </div>
            <div>
                <a href="#"><i class="fas fa-newspaper me-1"></i>Tin tức</a>
                <a href="#"><i class="fas fa-briefcase me-1"></i>Tuyển dụng</a>
                @if (!string.IsNullOrEmpty(token))
                {
                    <a asp-page="/Auth/Logout"><i class="fas fa-sign-out-alt me-1"></i>Đăng xuất</a>
                    <a asp-page="/Admin/Dashboard/Index"><i class="fas fa-tachometer-alt me-1"></i>Admin</a>
                }
                else
                {
                    <a asp-page="/Auth/Login"><i class="fas fa-user me-1"></i>Đăng nhập</a>
                }
            </div>
        </div>
    </div>

    <!-- ============ MAIN HEADER ============ -->
    <div class="main-header">
        <div class="container">
            <div class="d-flex align-items-center gap-3 flex-wrap">
                <!-- Logo -->
                <a href="/" class="logo me-2">Macvilla</a>

                <!-- Search bar -->
                <div class="search-bar flex-grow-1">
                    <form method="get" action="/">
                        <div class="input-group">
                            <input type="text" class="form-control" placeholder="Tìm kiếm sản phẩm..." />
                            <button type="submit"><i class="fas fa-search"></i></button>
                        </div>
                    </form>
                </div>

                <!-- Cart -->
                <a href="/Cart" class="cart-btn position-relative">
                    <i class="fas fa-shopping-cart me-1"></i>Giỏ hàng
                    <span class="cart-badge">0</span>
                </a>
            </div>
        </div>
    </div>

    <!-- ============ NAV MENU ============ -->
    <div class="nav-menu">
        <div class="container">
            <ul class="nav-list">
                <li><a href="/"><i class="fas fa-home me-1"></i>Trang chủ</a></li>
                <li><a href="/#categories"><i class="fas fa-th-large me-1"></i>Danh mục sản phẩm</a></li>
            </ul>
        </div>
    </div>

    <!-- ============ MAIN CONTENT ============ -->
    <div class="container" style="max-width:1200px;">
        
        <!-- Page Title -->
        <div class="page-title">
            <h1><i class="fas fa-shopping-cart me-2"></i>Giỏ hàng của bạn</h1>
        </div>

        <!-- Cart Content -->
        <div class="cart-content">
            <div class="row">
                <!-- Cart Items Column -->
                <div class="col-lg-8">
                    <div class="cart-items-wrapper">
                        <!-- Cart Header -->
                        <div class="cart-header">
                            <div class="cart-col-product">Sản phẩm</div>
                            <div class="cart-col-price">Giá</div>
                            <div class="cart-col-quantity">Số lượng</div>
                            <div class="cart-col-subtotal">Thành tiền</div>
                            <div class="cart-col-action"></div>
                        </div>

                        <!-- Cart Items Container -->
                        <div id="cart-items-container">
                            <!-- Loading State -->
                            <div id="cart-loading" class="cart-loading">
                                <div class="spinner-border text-success" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                                <p>Đang tải giỏ hàng...</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Cart Summary Column -->
                <div class="col-lg-4">
                    <div id="cart-summary" class="cart-summary">
                        <div class="summary-title">Tổng quan đơn hàng</div>
                        
                        <div class="summary-row">
                            <span>Số sản phẩm:</span>
                            <span id="cart-item-count">0</span>
                        </div>
                        
                        <div class="summary-row">
                            <span>Tạm tính:</span>
                            <span id="cart-subtotal">0 ₫</span>
                        </div>
                        
                        <div class="summary-row">
                            <span>Giảm giá:</span>
                            <span class="text-success">0 ₫</span>
                        </div>
                        
                        <hr />
                        
                        <div class="summary-total">
                            <span>Tổng cộng:</span>
                            <span id="cart-total-price">0 ₫</span>
                        </div>

                        <div class="summary-actions">
                            <a href="/Checkout" class="btn-checkout">
                                Tiến hành thanh toán <i class="fas fa-arrow-right ms-1"></i>
                            </a>
                            <a href="/" class="btn-continue">
                                <i class="fas fa-arrow-left me-1"></i>Tiếp tục mua sắm
                            </a>
                        </div>

                        <div class="summary-benefits">
                            <div class="benefit-item">
                                <i class="fas fa-truck"></i>
                                <span>Miễn phí vận chuyển đơn từ 2 triệu</span>
                            </div>
                            <div class="benefit-item">
                                <i class="fas fa-shield-alt"></i>
                                <span>Bảo hành chính hãng 24 tháng</span>
                            </div>
                            <div class="benefit-item">
                                <i class="fas fa-undo"></i>
                                <span>Đổi trả trong 30 ngày</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <!-- ============ FOOTER ============ -->
    <footer class="footer-main mt-4">
        <div class="container">
            <div class="row g-4">
                <div class="col-12 col-md-4">
                    <h5><i class="fas fa-home me-2"></i>Macvilla</h5>
                    <p>Hệ thống phân phối thiết bị vệ sinh và nhà bếp hàng đầu Việt Nam.</p>
                </div>
                <div class="col-6 col-md-2">
                    <h5>Hỗ Trợ</h5>
                    <a href="#">Chính sách đổi trả</a>
                    <a href="#">Chính sách bảo hành</a>
                </div>
                <div class="col-6 col-md-2">
                    <h5>Hệ Thống Cửa Hàng</h5>
                    <a href="#">Hà Nội</a>
                    <a href="#">TP.HCM</a>
                </div>
                <div class="col-12 col-md-4">
                    <h5>Liên Hệ</h5>
                    <p>Hotline: 1800 6060</p>
                </div>
            </div>
        </div>
    </footer>
    <div class="footer-bottom">
        <div class="container">
            &copy; 2026 Macvilla. Bảo lưu mọi quyền.
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/cart.js"></script>
    <script>
        // Update item count and subtotal display
        document.addEventListener('DOMContentLoaded', function() {
            // This will be called after cart.js loads
            if (typeof loadCart === 'function') {
                loadCart();
            }
        });
    </script>
</body>
</html>
