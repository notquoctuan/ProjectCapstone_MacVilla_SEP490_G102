@{
    Layout = null;
    var page = ViewContext.RouteData.Values["page"]?.ToString()?.ToLower() ?? string.Empty;

    bool IsActive(string prefix)
    {
        return page.StartsWith(prefix.ToLower());
    }
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MacVilla Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #2E7D32;
            --primary-light: #4CAF50;
            --primary-dark: #1B5E20;
            --primary-bg: #F1F8E9;
            --sidebar-w: 256px;
            --header-h: 60px;
            --text-main: #1a1a2e;
            --text-muted: #6b7280;
            --border: #e5e7eb;
            --surface: #ffffff;
            --bg: #f8fafc;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Be Vietnam Pro', sans-serif;
            background: var(--bg);
            color: var(--text-main);
        }

        /* ── HEADER ── */
        .mv-header {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            height: var(--header-h);
            background: var(--primary-dark);
            z-index: 1050;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 24px 0 0;
            box-shadow: 0 1px 8px rgba(0,0,0,.25);
        }

        .mv-header-brand {
            width: var(--sidebar-w);
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 0 20px;
            border-right: 1px solid rgba(255,255,255,.12);
            height: 100%;
        }

            .mv-header-brand .brand-text {
                color: #fff;
                font-weight: 700;
                font-size: .95rem;
                letter-spacing: .5px;
            }

            .mv-header-brand .brand-sub {
                color: rgba(255,255,255,.6);
                font-size: .7rem;
                text-transform: uppercase;
                letter-spacing: 1px;
            }

        .mv-header-right {
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .mv-header-right .admin-name {
                color: rgba(255,255,255,.9);
                font-size: .85rem;
            }

        /* ── SIDEBAR ── */
        .mv-sidebar {
            position: fixed;
            top: var(--header-h);
            left: 0;
            bottom: 0;
            width: var(--sidebar-w);
            background: var(--surface);
            border-right: 1px solid var(--border);
            overflow-y: auto;
            z-index: 1000;
            padding: 16px 0;
        }

            .mv-sidebar .nav-section {
                padding: 8px 16px 4px;
                font-size: .65rem;
                font-weight: 700;
                letter-spacing: 1.2px;
                text-transform: uppercase;
                color: var(--text-muted);
            }

            .mv-sidebar a.nav-item {
                display: flex;
                align-items: center;
                gap: 12px;
                padding: 10px 20px;
                color: #374151;
                text-decoration: none;
                font-size: .875rem;
                font-weight: 500;
                transition: all .15s;
                border-left: 3px solid transparent;
                margin: 1px 0;
            }

                .mv-sidebar a.nav-item i {
                    font-size: 1.05rem;
                    color: var(--text-muted);
                    transition: .15s;
                }

                .mv-sidebar a.nav-item:hover {
                    background: var(--primary-bg);
                    color: var(--primary);
                    border-left-color: var(--primary-light);
                }

                    .mv-sidebar a.nav-item:hover i {
                        color: var(--primary);
                    }

                .mv-sidebar a.nav-item.active {
                    background: var(--primary-bg);
                    color: var(--primary-dark);
                    font-weight: 600;
                    border-left-color: var(--primary);
                }

                    .mv-sidebar a.nav-item.active i {
                        color: var(--primary);
                    }

            .mv-sidebar .nav-divider {
                height: 1px;
                background: var(--border);
                margin: 10px 16px;
            }

        /* ── MAIN ── */
        .mv-main {
            margin-left: var(--sidebar-w);
            padding-top: var(--header-h);
            min-height: 100vh;
        }

        .mv-content {
            padding: 28px 32px;
        }

        .mv-page-header {
            margin-bottom: 24px;
        }

            .mv-page-header h1 {
                font-size: 1.4rem;
                font-weight: 700;
                color: var(--text-main);
            }

            .mv-page-header p {
                color: var(--text-muted);
                font-size: .85rem;
                margin-top: 2px;
            }

        /* ── CARD ── */
        .mv-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 12px;
            overflow: hidden;
        }

        .mv-card-header {
            padding: 16px 20px;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

            .mv-card-header h5 {
                font-size: .95rem;
                font-weight: 600;
                margin: 0;
            }

        .mv-card-body {
            padding: 20px;
        }

        /* ── BUTTONS ── */
        .btn-primary-mv {
            background: var(--primary);
            border: none;
            color: #fff;
            font-weight: 500;
            border-radius: 8px;
            padding: 8px 16px;
            font-size: .85rem;
            transition: .2s;
        }

            .btn-primary-mv:hover {
                background: var(--primary-dark);
                color: #fff;
            }

        .btn-outline-mv {
            border: 1px solid var(--primary);
            color: var(--primary);
            background: transparent;
            border-radius: 8px;
            padding: 8px 16px;
            font-size: .85rem;
            transition: .2s;
        }

            .btn-outline-mv:hover {
                background: var(--primary-bg);
                color: var(--primary-dark);
            }

        /* ── TABLE ── */
        .mv-table {
            width: 100%;
            border-collapse: collapse;
        }

            .mv-table thead th {
                background: #f9fafb;
                padding: 10px 14px;
                font-size: .75rem;
                font-weight: 600;
                text-transform: uppercase;
                letter-spacing: .5px;
                color: var(--text-muted);
                border-bottom: 1px solid var(--border);
                white-space: nowrap;
            }

            .mv-table tbody td {
                padding: 12px 14px;
                border-bottom: 1px solid #f3f4f6;
                vertical-align: middle;
                font-size: .875rem;
            }

            .mv-table tbody tr:hover {
                background: #fafbfc;
            }

            .mv-table tbody tr:last-child td {
                border-bottom: none;
            }

        /* ── BADGE ── */
        .badge-status {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 3px 10px;
            border-radius: 20px;
            font-size: .75rem;
            font-weight: 500;
        }

        .badge-enable {
            background: #dcfce7;
            color: #15803d;
        }

        .badge-disable {
            background: #fee2e2;
            color: #dc2626;
        }

        .badge-pending {
            background: #fef3c7;
            color: #d97706;
        }

        .badge-active {
            background: #dcfce7;
            color: #15803d;
        }

        .badge-processing {
            background: #dbeafe;
            color: #1d4ed8;
        }

        .badge-shipped {
            background: #ede9fe;
            color: #7c3aed;
        }

        .badge-completed {
            background: #dcfce7;
            color: #15803d;
        }

        .badge-cancelled {
            background: #fee2e2;
            color: #dc2626;
        }

        /* ── FORM ── */
        .form-control-mv, .form-select-mv {
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 8px 12px;
            font-size: .875rem;
            font-family: inherit;
            background: #fff;
            width: 100%;
            transition: border-color .15s, box-shadow .15s;
        }

            .form-control-mv:focus, .form-select-mv:focus {
                outline: none;
                border-color: var(--primary-light);
                box-shadow: 0 0 0 3px rgba(76,175,80,.1);
            }

        .form-label-mv {
            font-size: .8rem;
            font-weight: 600;
            color: #374151;
            margin-bottom: 5px;
            display: block;
        }

        /* ── PAGINATION ── */
        .mv-pagination {
            display: flex;
            gap: 4px;
            justify-content: center;
            flex-wrap: wrap;
        }

            .mv-pagination a, .mv-pagination span {
                width: 34px;
                height: 34px;
                display: flex;
                align-items: center;
                justify-content: center;
                border-radius: 8px;
                font-size: .85rem;
                text-decoration: none;
            }

            .mv-pagination a {
                color: var(--text-main);
                border: 1px solid var(--border);
                transition: .15s;
            }

                .mv-pagination a:hover {
                    background: var(--primary-bg);
                    border-color: var(--primary-light);
                    color: var(--primary);
                }

            .mv-pagination span.active {
                background: var(--primary);
                color: #fff;
                border: 1px solid var(--primary);
            }

        /* ── TOAST ── */
        #toast-container {
            position: fixed;
            bottom: 24px;
            right: 24px;
            z-index: 9999;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .mv-toast {
            padding: 12px 18px;
            border-radius: 10px;
            font-size: .875rem;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 10px;
            box-shadow: 0 4px 20px rgba(0,0,0,.15);
            animation: slideIn .3s ease;
            min-width: 260px;
        }

            .mv-toast.success {
                background: #15803d;
                color: #fff;
            }

            .mv-toast.error {
                background: #dc2626;
                color: #fff;
            }

            .mv-toast.info {
                background: #1d4ed8;
                color: #fff;
            }

        @@keyframes slideIn {
            from {
                transform: translateX(120%);
                opacity: 0;
            }

            to {
                transform: translateX(0);
                opacity: 1;
            }
        }

        /* ── MODAL ── */
        .mv-modal-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,.5);
            z-index: 2000;
            display: none;
            align-items: center;
            justify-content: center;
        }

            .mv-modal-overlay.show {
                display: flex;
            }

        .mv-modal {
            background: #fff;
            border-radius: 14px;
            max-width: 480px;
            width: calc(100% - 32px);
            max-height: 90vh;
            overflow-y: auto;
            box-shadow: 0 20px 60px rgba(0,0,0,.2);
        }

        .mv-modal-header {
            padding: 20px 24px 0;
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
        }

            .mv-modal-header h5 {
                font-size: 1rem;
                font-weight: 700;
            }

        .mv-modal-body {
            padding: 20px 24px;
        }

        .mv-modal-footer {
            padding: 16px 24px;
            border-top: 1px solid var(--border);
            display: flex;
            gap: 8px;
            justify-content: flex-end;
        }

        .btn-close-mv {
            background: none;
            border: none;
            font-size: 1.2rem;
            cursor: pointer;
            color: var(--text-muted);
            line-height: 1;
        }

            .btn-close-mv:hover {
                color: var(--text-main);
            }

        /* ── STATS CARD ── */
        .stat-card {
            border: 1px solid var(--border);
            border-radius: 12px;
            background: #fff;
            padding: 20px 22px;
            display: flex;
            align-items: center;
            gap: 16px;
            transition: box-shadow .2s;
        }

            .stat-card:hover {
                box-shadow: 0 4px 20px rgba(0,0,0,.08);
            }

        .stat-icon {
            width: 48px;
            height: 48px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.35rem;
            flex-shrink: 0;
        }

        .stat-val {
            font-size: 1.7rem;
            font-weight: 700;
            line-height: 1;
        }

        .stat-label {
            font-size: .78rem;
            color: var(--text-muted);
            margin-top: 3px;
            font-weight: 500;
        }

        /* ── IMAGE PREVIEW ── */
        .img-thumb {
            width: 56px;
            height: 56px;
            object-fit: cover;
            border-radius: 8px;
            border: 1px solid var(--border);
        }

        .img-preview-grid {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-top: 10px;
        }

        .img-preview-item {
            position: relative;
            display: inline-block;
        }

            .img-preview-item img {
                width: 80px;
                height: 80px;
                object-fit: cover;
                border-radius: 8px;
                border: 2px solid var(--border);
            }

            .img-preview-item .img-main-badge {
                position: absolute;
                top: 4px;
                left: 4px;
                background: var(--primary);
                color: #fff;
                font-size: .6rem;
                padding: 1px 5px;
                border-radius: 4px;
                font-weight: 600;
            }

            .img-preview-item .btn-del-img {
                position: absolute;
                top: 4px;
                right: 4px;
                width: 20px;
                height: 20px;
                background: #dc2626;
                color: #fff;
                border: none;
                border-radius: 50%;
                cursor: pointer;
                font-size: .75rem;
                display: flex;
                align-items: center;
                justify-content: center;
            }

        /* ── SEARCH BAR ── */
        .search-bar {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            background: #fff;
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 16px;
            margin-bottom: 16px;
        }

            .search-bar .form-group {
                display: flex;
                flex-direction: column;
                gap: 4px;
            }

        /* ── SCROLLBAR ── */
        ::-webkit-scrollbar {
            width: 5px;
            height: 5px;
        }

        ::-webkit-scrollbar-track {
            background: transparent;
        }

        ::-webkit-scrollbar-thumb {
            background: #d1d5db;
            border-radius: 4px;
        }
    </style>
</head>
<body>
    <header class="mv-header">
        <div class="mv-header-brand">
            <div>
                <div class="brand-text">MacVilla</div>
                <div class="brand-sub">Admin Panel</div>
            </div>
        </div>
        <div class="mv-header-right">
            <span class="admin-name"><i class="bi bi-person-circle me-1"></i> @(ViewData["AdminName"] ?? "Admin")</span>
            <div class="dropdown">
                <button class="btn btn-sm btn-link text-white p-1 ms-2" data-bs-toggle="dropdown" style="text-decoration:none;">
                    <i class="bi bi-chevron-down" style="font-size:.75rem;"></i>
                </button>
                <ul class="dropdown-menu dropdown-menu-end shadow border-0" style="min-width:160px; font-size:.85rem; border-radius:10px;">
                    <li><a class="dropdown-item py-2 text-danger" href="/Auth/Logout"><i class="bi bi-box-arrow-right me-2"></i>Đăng xuất</a></li>
                </ul>
            </div>
        </div>
    </header>

    <nav class="mv-sidebar">
        <div class="nav-section">Menu chính</div>
        @{
            var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
        }
        <a class="nav-item @(currentPage.Contains("/Admin/Dashboard") ? "active" : "")" href="/Admin/Dashboard">
            <i class="bi bi-speedometer2"></i> Tổng quan
        </a>
        <a class="nav-item @(currentPage.Contains("/Admin/Products") ? "active" : "")" href="/Admin/Products">
            <i class="bi bi-box-seam"></i> Sản phẩm
        </a>
        <a class="nav-item @(currentPage.Contains("/Admin/Categories") ? "active" : "")" href="/Admin/Categories">
            <i class="bi bi-tags"></i> Danh mục
        </a>
        <a class="nav-item @(currentPage.Contains("/Admin/Orders") ? "active" : "")" href="/Admin/Orders">
            <i class="bi bi-receipt-cutoff"></i> Đơn hàng
        </a>
        <a class="nav-item @(currentPage.Contains("/Admin/Users") ? "active" : "")" href="/Admin/Users">
            <i class="bi bi-people"></i> Người dùng
        </a>
        <div class="nav-divider"></div>
        <div class="nav-section">Hệ thống</div>
        <a class="nav-item" href="/Auth/Logout">
            <i class="bi bi-box-arrow-right"></i> Đăng xuất
        </a>
    </nav>

    <div class="mv-main">
        <div class="mv-content">
            @RenderBody()
        </div>
    </div>

    <div id="toast-container"></div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const API = 'https://localhost:7262';
        function getCookie(name) {
            const match = document.cookie.match(new RegExp('(^| )' + name + '=([^;]+)'));
            return match ? match[2] : '';
        }
        function getToken() {
            return sessionStorage.getItem('jwt') || getCookie('jwt') || localStorage.getItem('jwt') || '';
        }

        async function apiFetch(url, options = {}) {
            const token = getToken();
            const headers = { 'Content-Type': 'application/json', ...(options.headers || {}) };
            if (token) headers['Authorization'] = 'Bearer ' + token;
            const res = await fetch(API + url, { ...options, headers });
            if (res.status === 401) { window.location.href = '/Auth/Login'; throw new Error('Unauthorized'); }
            return res;
        }

        function showToast(msg, type = 'success') {
            const icons = { success: 'bi-check-circle-fill', error: 'bi-x-circle-fill', info: 'bi-info-circle-fill' };
            const el = document.createElement('div');
            el.className = `mv-toast ${type}`;
            el.innerHTML = `<i class="bi ${icons[type] || icons.info}"></i><span>${msg}</span>`;
            document.getElementById('toast-container').appendChild(el);
            setTimeout(() => el.remove(), 3500);
        }

        function confirmModal(title, msg, onConfirm) {
            const id = 'cm_' + Date.now();
            const div = document.createElement('div');
            div.className = 'mv-modal-overlay show';
            div.id = id;
            div.innerHTML = `
                <div class="mv-modal">
                    <div class="mv-modal-header"><h5>${title}</h5><button class="btn-close-mv" onclick="document.getElementById('${id}').remove()">&times;</button></div>
                    <div class="mv-modal-body"><p style="color:#6b7280;font-size:.9rem;">${msg}</p></div>
                    <div class="mv-modal-footer">
                        <button class="btn btn-sm btn-outline-secondary px-4" onclick="document.getElementById('${id}').remove()">Huỷ</button>
                        <button class="btn btn-sm btn-danger px-4" id="${id}_ok">Xác nhận</button>
                    </div>
                </div>`;
            document.body.appendChild(div);
            document.getElementById(id + '_ok').onclick = () => { document.getElementById(id).remove(); onConfirm(); };
        }

        function openModal(id) { document.getElementById(id).classList.add('show'); }
        function closeModal(id) { document.getElementById(id).classList.remove('show'); }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
