@page
@model MacVilla_Web.Pages.IndexModel
@using Microsoft.AspNetCore.Http
@{
    Layout = null;
    var token = HttpContext?.Session?.GetString("JWToken") ?? Request.Cookies["jwt"];
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Macvilla - Hệ thống thiết bị vệ sinh & nhà bếp</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />
    <!-- Homepage-specific green theme — does NOT affect other pages -->
    <link rel="stylesheet" href="~/css/homepage.css" />
</head>
<body class="homepage-theme">

<!-- ============ TOP BAR ============ -->
<div class="top-bar">
    <div class="container d-flex justify-content-between align-items-center flex-wrap gap-1">
        <div>
            <i class="fas fa-phone-alt me-1"></i>
            <strong>Hotline: 1800 6060</strong>
            <span class="separator d-md-inline"> | </span>
            <a href="#" class="d-md-inline"><i class="fas fa-store me-1"></i>Hệ thống showroom</a>
        </div>
        <div>
            <a href="#"><i class="fas fa-newspaper me-1"></i>Tin tức</a>
            <a href="#"><i class="fas fa-briefcase me-1"></i>Tuyển dụng</a>
            @if (!string.IsNullOrEmpty(token))
            {
                <a asp-page="/Auth/Logout"><i class="fas fa-sign-out-alt me-1"></i>Đăng xuất</a>
                <a asp-page="/Admin/Dashboard/Index"><i class="fas fa-tachometer-alt me-1"></i>Admin</a>
            }
            else
            {
                <a asp-page="/Auth/Login"><i class="fas fa-user me-1"></i>Đăng nhập</a>
            }
        </div>
    </div>
</div>

<!-- ============ MAIN HEADER ============ -->
<div class="main-header">
    <div class="container">
        <div class="d-flex align-items-center gap-3 flex-wrap">
            <!-- Logo -->
            <a href="/" class="logo me-2">Macvilla</a>

            <!-- Search bar -->
            <div class="search-bar flex-grow-1">
                <form method="get" action="/" id="searchForm">
                    <div class="input-group">
                        <input type="text"
                               name="SearchQuery"
                               id="searchInput"
                               class="form-control"
                               placeholder="Tìm kiếm sản phẩm..."
                               value="@Model.SearchQuery"
                               autocomplete="off" />
                        <button type="submit" id="searchBtn">
                            <i class="fas fa-search"></i>
                        </button>
                    </div>
                </form>
            </div>

            <!-- Region -->
            <button class="region-btn">
                <i class="fas fa-map-marker-alt me-1"></i>Hà Nội
            </button>

            <!-- Cart -->
            <div class="cart-wrapper position-relative">
                <button class="cart-btn position-relative" type="button" onclick="toggleCartDropdown()">
                    <i class="fas fa-shopping-cart me-1"></i>Giỏ hàng
                    <span class="cart-badge">0</span>
                </button>
                <div id="cartDropdown" class="cart-dropdown">
                    <div class="cart-empty">Giỏ hàng trống</div>
                    <div class="cart-items d-none"></div>
                    <div class="cart-footer d-none">
                        <div class="cart-total">
                            Tổng: <span id="cartTotal">0₫</span>
                        </div>
                        <button class="btn btn-sm btn-success w-100 mt-2" type="button">Thanh toán (demo)</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ============ NAV MENU ============ -->
<div class="nav-menu">
    <div class="container">
        <ul class="nav-list">
            <!-- Tất cả danh mục dropdown -->
            <li class="cat-mega-menu-wrapper">
                <a href="#categories">
                    <i class="fas fa-th-large me-1"></i>Tất cả danh mục
                    @if (Model.CategoryTree.Any())
                    {
                        <i class="fas fa-chevron-down ms-1" style="font-size:10px;"></i>
                    }
                </a>
                @if (Model.CategoryTree.Any())
                {
                    <div class="cat-mega-dropdown">
                        <ul class="cat-mega-parents">
                            @foreach (var cat in Model.CategoryTree)
                            {
                                <li class="@(cat.Children.Any() ? "has-children" : "")">
                                    <a href="#">
                                        @cat.CategoryName
                                        @if (cat.Children.Any())
                                        {
                                            <i class="fas fa-chevron-right" style="font-size:10px;"></i>
                                        }
                                    </a>
                                    @if (cat.Children.Any())
                                    {
                                        <ul class="cat-mega-children">
                                            @foreach (var child in cat.Children)
                                            {
                                                <li><a href="#">@child.CategoryName</a></li>
                                            }
                                        </ul>
                                    }
                                </li>
                            }
                        </ul>
                    </div>
                }
            </li>
            <!-- Parent category quick-links -->
            @foreach (var cat in Model.CategoryTree.Take(9))
            {
                <li><a href="#">@cat.CategoryName</a></li>
            }
        </ul>
    </div>
</div>

<!-- ============ MAIN CONTENT ============ -->
<div class="container" style="max-width:1200px;">

    <!-- Search Results -->
    @if (Model.HasSearched)
    {
        <div class="search-results-overlay mt-3">
            <h5 class="mb-3">
                <i class="fas fa-search text-danger me-2"></i>
                Kết quả tìm kiếm cho: <strong>"@Model.SearchQuery"</strong>
                @if (string.IsNullOrEmpty(Model.SearchError))
                {
                    <span class="text-muted fs-6 fw-normal">(@Model.SearchResults.Count sản phẩm)</span>
                }
            </h5>
            @if (!string.IsNullOrEmpty(Model.SearchError))
            {
                <div class="alert alert-warning"><i class="fas fa-exclamation-triangle me-1"></i>@Model.SearchError</div>
            }
            else if (Model.SearchResults.Any())
            {
                <div class="row row-cols-2 row-cols-md-4 g-3">
                    @foreach (var p in Model.SearchResults)
                    {
                        <div class="col">
                            <div class="product-card">
                                <div class="product-img-wrap">
                                    @if (!string.IsNullOrEmpty(p.ImageUrl))
                                    {
                                        <img src="@p.ImageUrl" alt="@p.Name" />
                                    }
                                    else
                                    {
                                        <div class="product-img-placeholder"><i class="fas fa-box"></i></div>
                                    }
                                </div>
                                    <div class="product-body">
                                    <div class="product-name">@p.Name</div>
                                    <div class="product-rating">
                                        <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="far fa-star"></i>
                                    </div>
                                    <div class="product-price">
                                        <span class="price-new">@((p.Price ?? 0).ToString("N0"))₫</span>
                                    </div>
                                    <button class="btn-add-cart"
                                            onclick="addToCart(@p.ProductId, '@p.Name'.trim(), @((p.Price ?? 0)), '@(p.ImageUrl ?? "")')">
                                        <i class="fas fa-cart-plus me-1"></i>Thêm vào giỏ
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-muted"><i class="fas fa-info-circle me-1"></i>Không tìm thấy sản phẩm nào phù hợp.</p>
            }
        </div>
    }

    @if (!Model.HasSearched || !Model.SearchResults.Any())
    {
    <!-- ===== BANNER SLIDER ===== -->
    <div class="banner-section mt-3 rounded overflow-hidden">
        @if (Model.Banners.Any())
        {
            <div id="bannerCarousel" class="carousel slide" data-bs-ride="carousel" data-bs-interval="4000">
                <div class="carousel-indicators">
                    @for (int bi = 0; bi < Model.Banners.Count; bi++)
                    {
                        <button type="button" data-bs-target="#bannerCarousel" data-bs-slide-to="@bi" class="@(bi == 0 ? "active" : "")"></button>
                    }
                </div>
                <div class="carousel-inner">
                    @for (int bi = 0; bi < Model.Banners.Count; bi++)
                    {
                        var banner = Model.Banners[bi];
                        <div class="carousel-item @(bi == 0 ? "active" : "")">
                            @if (!string.IsNullOrEmpty(banner.ImageUrl))
                            {
                                <a href="@(banner.LinkUrl ?? "#")">
                                    <img src="@banner.ImageUrl" class="d-block w-100" alt="@banner.Title" style="max-height:400px;object-fit:cover;" />
                                </a>
                            }
                            else
                            {
                                <div class="banner-placeholder" style="background: linear-gradient(135deg,#16a34a 0%,#064e3b 100%);">
                                    <h2 style="font-weight:800;letter-spacing:1px;">@banner.Title</h2>
                                    @if (!string.IsNullOrEmpty(banner.LinkUrl))
                                    {
                                        <a href="@banner.LinkUrl" class="btn mt-2" style="background:#FFD700;color:#333;font-weight:700;border-radius:4px;">Xem thêm</a>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
                <button class="carousel-control-prev" type="button" data-bs-target="#bannerCarousel" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon"></span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#bannerCarousel" data-bs-slide="next">
                    <span class="carousel-control-next-icon"></span>
                </button>
            </div>
        }
        else
        {
            <!-- Fallback static banners when API is unavailable -->
            <div id="bannerCarousel" class="carousel slide" data-bs-ride="carousel" data-bs-interval="4000">
                <div class="carousel-indicators">
                    <button type="button" data-bs-target="#bannerCarousel" data-bs-slide-to="0" class="active"></button>
                    <button type="button" data-bs-target="#bannerCarousel" data-bs-slide-to="1"></button>
                    <button type="button" data-bs-target="#bannerCarousel" data-bs-slide-to="2"></button>
                </div>
                <div class="carousel-inner">
                    <div class="carousel-item active">
                        <div class="banner-placeholder" style="background: linear-gradient(135deg,#16a34a 0%,#064e3b 100%);">
                            <i class="fas fa-bath" style="font-size:60px;opacity:0.3;margin-bottom:16px;"></i>
                            <h2 style="font-weight:800;letter-spacing:1px;">COMBO THIẾT BỊ VỆ SINH</h2>
                            <p style="font-size:16px;opacity:0.85;">Ưu đãi lên đến 40% - Số lượng có hạn</p>
                            <a href="#" class="btn mt-2" style="background:#FFD700;color:#333;font-weight:700;border-radius:4px;">Mua ngay</a>
                        </div>
                    </div>
                    <div class="carousel-item">
                        <div class="banner-placeholder" style="background: linear-gradient(135deg,#1a73e8 0%,#0d47a1 100%);">
                            <i class="fas fa-utensils" style="font-size:60px;opacity:0.3;margin-bottom:16px;"></i>
                            <h2 style="font-weight:800;letter-spacing:1px;">COMBO THIẾT BỊ NHÀ BẾP</h2>
                            <p style="font-size:16px;opacity:0.85;">Thương hiệu hàng đầu - Bảo hành 24 tháng</p>
                            <a href="#" class="btn mt-2" style="background:#FFD700;color:#333;font-weight:700;border-radius:4px;">Khám phá</a>
                        </div>
                    </div>
                    <div class="carousel-item">
                        <div class="banner-placeholder" style="background: linear-gradient(135deg,#2d8a4e 0%,#1a5c35 100%);">
                            <i class="fas fa-th" style="font-size:60px;opacity:0.3;margin-bottom:16px;"></i>
                            <h2 style="font-weight:800;letter-spacing:1px;">GẠCH LÁT NỀN - ỐP TƯỜNG</h2>
                            <p style="font-size:16px;opacity:0.85;">Hàng ngàn mẫu mã - Giá tốt nhất thị trường</p>
                            <a href="#" class="btn mt-2" style="background:#FFD700;color:#333;font-weight:700;border-radius:4px;">Xem thêm</a>
                        </div>
                    </div>
                </div>
                <button class="carousel-control-prev" type="button" data-bs-target="#bannerCarousel" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon"></span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#bannerCarousel" data-bs-slide="next">
                    <span class="carousel-control-next-icon"></span>
                </button>
            </div>
        }
    </div>

    <!-- ===== CATEGORIES GRID ===== -->
    <div class="categories-section mt-3 px-3 rounded" id="categories">
        <div class="section-title">Danh Mục Sản Phẩm</div>

        @{
            var categoryColors = new[] { "#16a34a","#15803d","#1a73e8","#0d47a1","#f7a400","#2d8a4e","#7b1fa2","#00838f","#e64a19","#546e7a","#ad1457","#6d4c41" };
            var staticCats = new[]
            {
                new { Name = "Combo Thiết Bị Vệ Sinh", Icon = "fa-bath", Color = "#16a34a" },
                new { Name = "Combo Thiết Bị Nhà Bếp", Icon = "fa-utensils", Color = "#15803d" },
                new { Name = "Gạch Lát Nền", Icon = "fa-th", Color = "#1a73e8" },
                new { Name = "Gạch Ốp Tường", Icon = "fa-border-all", Color = "#0d47a1" },
                new { Name = "Bồn Cầu", Icon = "fa-toilet", Color = "#f7a400" },
                new { Name = "Bồn Tắm", Icon = "fa-hot-tub", Color = "#2d8a4e" },
                new { Name = "Sen Tắm", Icon = "fa-shower", Color = "#7b1fa2" },
                new { Name = "Lavabo", Icon = "fa-sink", Color = "#00838f" },
                new { Name = "Bếp Từ", Icon = "fa-fire", Color = "#e64a19" },
                new { Name = "Máy Hút Mùi", Icon = "fa-wind", Color = "#546e7a" },
                new { Name = "Máy Rửa Bát", Icon = "fa-soap", Color = "#ad1457" },
                new { Name = "Lò Nướng", Icon = "fa-bread-slice", Color = "#6d4c41" },
            };
        }

        @if (Model.CategoryTree.Any())
        {
            <div class="row row-cols-3 row-cols-sm-4 row-cols-md-6 g-2">
            @foreach (var parentCat in Model.CategoryTree)
            {
                var pIdx = Model.CategoryTree.IndexOf(parentCat);
                var pColor = categoryColors[pIdx % categoryColors.Length];
                <div class="col">
                    <div class="cat-item">
                        <div class="cat-icon-placeholder" style="background: linear-gradient(135deg, @pColor, @pColor)">
                            <i class="fas fa-layer-group"></i>
                        </div>
                        <div class="cat-name">@parentCat.CategoryName</div>
                    </div>
                </div>
            }
            </div>
        }
        else
        {
            <!-- Fallback static categories -->
            <div class="row row-cols-3 row-cols-sm-4 row-cols-md-6 g-2">
                @foreach (var cat in staticCats)
                {
                    <div class="col">
                        <div class="cat-item">
                            <div class="cat-icon-placeholder" style="background: linear-gradient(135deg, @cat.Color, @cat.Color)">
                                <i class="fas @cat.Icon"></i>
                            </div>
                            <div class="cat-name">@cat.Name</div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <!-- ===== FEATURED PRODUCTS ===== -->
    <div class="products-section mt-3 px-3 rounded">
        <div class="section-header">
            <div>
                <span class="section-title mb-0" style="display:inline;">Sản Phẩm Nổi Bật</span>
                <span class="badge-hot">HOT SALE</span>
            </div>
            <a href="#">Xem tất cả <i class="fas fa-chevron-right"></i></a>
        </div>

        @if (Model.FeaturedProducts.Any())
        {
            <div class="row row-cols-2 row-cols-md-4 g-3">
                @foreach (var product in Model.FeaturedProducts)
                {
                    var discountPct = Random.Shared.Next(10, 40);
                    var oldPrice = product.Price * (1 + discountPct / 100m);
                    <div class="col">
                        <div class="product-card">
                            <div class="product-img-wrap">
                                @if (!string.IsNullOrEmpty(product.ImageUrl))
                                {
                                    <img src="@product.ImageUrl" alt="@product.Name" loading="lazy" />
                                }
                                else
                                {
                                    <div class="product-img-placeholder"><i class="fas fa-box"></i></div>
                                }
                                <span class="discount-badge">-@discountPct%</span>
                            </div>
                            <div class="product-body">
                                <div class="product-name">@product.Name</div>
                                <div class="product-rating">
                                    <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="far fa-star"></i>
                                    <span style="color:#888;font-size:11px;margin-left:3px;">(4.0)</span>
                                </div>
                                <div class="product-price">
                                    <span class="price-new">@((product.Price ?? 0).ToString("N0"))₫</span>
                                    <span class="price-old">@((oldPrice ?? 0).ToString("N0"))₫</span>
                                </div>
                                <button class="btn-add-cart"
                                        onclick="addToCart(@product.ProductId, '@product.Name'.trim(), @((product.Price ?? 0)), '@(product.ImageUrl ?? "")')">
                                    <i class="fas fa-cart-plus me-1"></i>Thêm vào giỏ
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <!-- Placeholder product cards when API is unavailable -->
            <div class="row row-cols-2 row-cols-md-4 g-3">
                @for (int i = 1; i <= 8; i++)
                {
                    <div class="col">
                        <div class="product-card">
                            <div class="product-img-wrap">
                                <div class="product-img-placeholder"><i class="fas fa-box"></i></div>
                                <span class="discount-badge">-20%</span>
                            </div>
                            <div class="product-body">
                                <div class="product-name">Sản phẩm mẫu @i</div>
                                <div class="product-rating">
                                    <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="far fa-star"></i>
                                </div>
                                <div class="product-price">
                                    <span class="price-new">@((800000 + i * 100000).ToString("N0"))₫</span>
                                    <span class="price-old">@((1000000 + i * 125000).ToString("N0"))₫</span>
                                </div>
                                <button class="btn-add-cart"><i class="fas fa-cart-plus me-1"></i>Thêm vào giỏ</button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
    } @* end: homepage sections *@

</div><!-- /container -->

<!-- ============ FOOTER ============ -->
<footer class="footer-main mt-4">
    <div class="container">
        <div class="row g-4">
            <!-- Company Info -->
            <div class="col-12 col-md-4">
                <h5><i class="fas fa-home me-2"></i>Macvilla</h5>
                <p>Hệ thống phân phối thiết bị vệ sinh và nhà bếp hàng đầu Việt Nam. Cam kết chất lượng, giá cạnh tranh và dịch vụ hậu mãi tốt nhất.</p>
                <p><i class="fas fa-map-marker-alt me-2 text-danger"></i>123 Đường Láng, Đống Đa, Hà Nội</p>
                <p><i class="fas fa-phone me-2 text-danger"></i>1800 6060</p>
                <p><i class="fas fa-envelope me-2 text-danger"></i>info&#64;shome.vn</p>
            </div>

            <!-- Support -->
            <div class="col-6 col-md-2">
                <h5>Hỗ Trợ</h5>
                <a href="#">Chính sách đổi trả</a>
                <a href="#">Chính sách bảo hành</a>
                <a href="#">Phương thức thanh toán</a>
                <a href="#">Chính sách giao hàng</a>
                <a href="#">Điều khoản & điều kiện</a>
            </div>

            <!-- Store System -->
            <div class="col-6 col-md-2">
                <h5>Hệ Thống Cửa Hàng</h5>
                <a href="#"><i class="fas fa-store me-1"></i>Hà Nội - Đống Đa</a>
                <a href="#"><i class="fas fa-store me-1"></i>Hà Nội - Cầu Giấy</a>
                <a href="#"><i class="fas fa-store me-1"></i>TP.HCM - Q1</a>
                <a href="#"><i class="fas fa-store me-1"></i>TP.HCM - Q7</a>
                <a href="#"><i class="fas fa-store me-1"></i>Đà Nẵng</a>
            </div>

            <!-- Contact & Social -->
            <div class="col-12 col-md-4">
                <h5>Liên Hệ & Mạng Xã Hội</h5>
                <p><strong style="color:#fff;">Hotline CSKH:</strong> 1800 6060 (miễn phí)</p>
                <p><strong style="color:#fff;">Email:</strong> support&#64;shome.vn</p>
                <div class="social-icons mb-3">
                    <a href="#" title="Facebook"><i class="fab fa-facebook-f"></i></a>
                    <a href="#" title="YouTube"><i class="fab fa-youtube"></i></a>
                    <a href="#" title="Zalo"><i class="fas fa-comment-dots"></i></a>
                </div>
                <div>
                    <p style="color:#aaa;font-size:12px;margin-bottom:6px;">Phương thức thanh toán:</p>
                    <div class="payment-icons">
                        <span>VISA</span>
                        <span>JCB</span>
                        <span>MASTER</span>
                        <span>ATM</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</footer>
<div class="footer-bottom">
    <div class="container">
        &copy; 2026 Macvilla. Bảo lưu mọi quyền. |
        <a href="#" style="color:#16a34a;text-decoration:none;">Chính sách bảo mật</a>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script>
    // Search validation
    document.getElementById('searchForm').addEventListener('submit', function (e) {
        var q = document.getElementById('searchInput').value.trim();
        if (!q) {
            e.preventDefault();
            document.getElementById('searchInput').classList.add('is-invalid');
            alert('Vui lòng nhập từ khóa tìm kiếm!');
            return;
        }
        if (q.length > 100) {
            e.preventDefault();
            document.getElementById('searchInput').classList.add('is-invalid');
            alert('Từ khóa tìm kiếm không được vượt quá 100 ký tự!');
            return;
        }
        // Prevent invalid characters (allow letters, numbers, spaces, Vietnamese)
        var invalid = /[<>"'\\;]/.test(q);
        if (invalid) {
            e.preventDefault();
            alert('Từ khóa chứa ký tự không hợp lệ!');
            return;
        }
        // Set trimmed value back
        document.getElementById('searchInput').value = q;
        document.getElementById('searchInput').classList.remove('is-invalid');
    });

    document.getElementById('searchInput').addEventListener('input', function () {
        this.classList.remove('is-invalid');
    });

    // Simple client-side cart using localStorage
    const CART_KEY = 'mv_cart';

    function loadCart() {
        try {
            const raw = localStorage.getItem(CART_KEY);
            return raw ? JSON.parse(raw) : [];
        } catch {
            return [];
        }
    }

    function saveCart(items) {
        localStorage.setItem(CART_KEY, JSON.stringify(items));
    }

    function formatPrice(v) {
        return (v || 0).toLocaleString('vi-VN') + '₫';
    }

    function renderCart() {
        const items = loadCart();
        const badge = document.querySelector('.cart-badge');
        const dropdown = document.getElementById('cartDropdown');
        const listEl = dropdown.querySelector('.cart-items');
        const emptyEl = dropdown.querySelector('.cart-empty');
        const footerEl = dropdown.querySelector('.cart-footer');

        const totalQty = items.reduce((s, x) => s + x.qty, 0);
        const totalPrice = items.reduce((s, x) => s + x.qty * x.price, 0);
        badge.textContent = totalQty;

        if (!items.length) {
            emptyEl.classList.remove('d-none');
            listEl.classList.add('d-none');
            footerEl.classList.add('d-none');
            return;
        }

        emptyEl.classList.add('d-none');
        listEl.classList.remove('d-none');
        footerEl.classList.remove('d-none');

        listEl.innerHTML = items.map(i => `
            <div class="cart-item">
                <div class="cart-thumb">
                    ${i.imageUrl ? `<img src="${i.imageUrl}" alt="${i.name}" />` : '<div class="cart-thumb-placeholder"><i class="fas fa-box"></i></div>'}
                </div>
                <div class="cart-info">
                    <div class="cart-name">${i.name}</div>
                    <div class="cart-meta">
                        <span>${formatPrice(i.price)}</span>
                        <span>x${i.qty}</span>
                    </div>
                </div>
                <button type="button" class="cart-remove" onclick="removeFromCart(${i.id})">
                    <i class="fas fa-times"></i>
                </button>
            </div>`).join('');

        document.getElementById('cartTotal').textContent = formatPrice(totalPrice);
    }

    function addToCart(id, name, price, imageUrl) {
        const items = loadCart();
        const existing = items.find(x => x.id === id);
        if (existing) existing.qty += 1;
        else items.push({ id, name, price, imageUrl, qty: 1 });
        saveCart(items);
        renderCart();

        var badge = document.querySelector('.cart-badge');
        badge.style.transition = 'transform 0.2s';
        badge.style.transform = 'scale(1.4)';
        setTimeout(function () { badge.style.transform = 'scale(1)'; }, 200);
    }

    function removeFromCart(id) {
        let items = loadCart();
        items = items.filter(x => x.id !== id);
        saveCart(items);
        renderCart();
    }

    function toggleCartDropdown() {
        const dropdown = document.getElementById('cartDropdown');
        dropdown.classList.toggle('show');
    }

    document.addEventListener('click', function (e) {
        const wrapper = document.querySelector('.cart-wrapper');
        const dropdown = document.getElementById('cartDropdown');
        if (!wrapper.contains(e.target)) {
            dropdown.classList.remove('show');
        }
    });

    // initial render
    renderCart();
</script>
</body>
</html>
