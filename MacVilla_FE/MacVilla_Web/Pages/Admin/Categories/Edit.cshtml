@page "{id:long}"
@model MacVilla_Web.Pages.Admin.Categories.EditModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sửa danh mục - MacVilla</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        :root {
            --mv-green-dark: #7DA100;
            --mv-green-light: #f9fff0;
            --mv-green-border: #e2f0d1;
        }

        body {
            background-color: #f4f6f9;
            font-family: 'Segoe UI', Tahoma, sans-serif;
            margin: 0;
        }

        .admin-header {
            background-color: var(--mv-green-dark);
            height: 65px;
            position: fixed;
            width: 100%;
            top: 0;
            z-index: 1050;
            padding: 0 30px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        .logo-custom {
            height: 35px;
            width: auto;
        }

        .admin-wrapper {
            margin-top: 65px;
            padding: 40px 20%; /* Cố định độ rộng cho mọi màn hình */
            min-height: calc(100vh - 115px);
        }

        .card-custom {
            border: none;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.08);
        }

        .card-header-mv {
            background-color: var(--mv-green-dark);
            color: #ffffff;
            font-weight: bold;
            text-transform: uppercase;
            padding: 1.2rem;
        }

        .form-control:focus, .form-select:focus {
            border-color: var(--mv-green-dark);
            box-shadow: 0 0 0 0.25rem rgba(125, 161, 0, 0.1);
        }

        .admin-footer {
            background-color: var(--mv-green-dark);
            color: #ffffff;
            padding: 15px 15%;
            font-size: 13px;
        }

        .btn-mv-save {
            background-color: var(--mv-green-dark);
            color: white;
            border: none;
            padding: 10px 30px;
            font-weight: 600;
            transition: 0.3s;
        }

            .btn-mv-save:hover {
                background-color: #6a8900;
                color: white;
                transform: translateY(-2px);
            }
    </style>
</head>
<body>
    <header class="admin-header d-flex align-items-center justify-content-between">
        <div class="d-flex align-items-center">
            <img src="~/Image/Logo/logo-macvilla.png" alt="MacVilla" class="logo-custom me-3">
            <span class="text-white fw-bold border-start ps-3 small text-uppercase">Quản trị danh mục</span>
        </div>

        <div class="dropdown">
            <button class="btn btn-link text-white text-decoration-none dropdown-toggle small" type="button" data-bs-toggle="dropdown">
                <i class="bi bi-person-circle me-1"></i> Admin MacVilla
            </button>
            <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                <li><a class="dropdown-item small" href="/Admin/Dashboard"><i class="bi bi-speedometer2 me-2"></i> Dashboard</a></li>
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item small text-danger" asp-page="/Auth/Logout"><i class="bi bi-box-arrow-right me-2"></i> Đăng xuất</a></li>
            </ul>
        </div>
    </header>

    <main class="admin-wrapper">
        <nav aria-label="breadcrumb" class="mb-4">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-page="./Index" class="text-decoration-none" style="color: var(--mv-green-dark)">Danh mục</a></li>
                <li class="breadcrumb-item active" aria-current="page">Sửa chi tiết</li>
            </ol>
        </nav>

        <div class="card card-custom">
            <div class="card-header card-header-mv">
                <i class="bi bi-pencil-square me-2"></i> Thông tin danh mục
            </div>
            <div class="card-body p-4 p-lg-5">
                <form method="post">
                    <input type="hidden" asp-for="Id" />

                    <div class="mb-4">
                        <label asp-for="UpdateRequest.CategoryName" class="form-label fw-bold small text-uppercase">Tên danh mục <span class="text-danger">*</span></label>
                        <input asp-for="UpdateRequest.CategoryName" class="form-control form-control-lg" placeholder="Nhập tên danh mục" required />
                        <span asp-validation-for="UpdateRequest.CategoryName" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="UpdateRequest.ParentCategoryId" class="form-label fw-bold small text-uppercase">Danh mục cha</label>
                        <select asp-for="UpdateRequest.ParentCategoryId" class="form-select form-select-lg">
                            <option value="">-- Không có (danh mục gốc) --</option>
                            @if (Model.ParentCategories != null)
                            {
                                @foreach (var c in Model.ParentCategories)
                                {
                                    @if (c.CategoryId != Model.Id)
                                    {
                                        <option value="@c.CategoryId">@c.CategoryName</option>
                                    }
                                }
                            }
                        </select>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                    {
                        <div class="alert alert-danger d-flex align-items-center">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            @Model.ErrorMessage
                        </div>
                    }

                    <div class="mt-5 pt-4 border-top d-flex gap-2">
                        <button type="submit" class="btn btn-mv-save shadow">
                            <i class="bi bi-save me-2"></i> CẬP NHẬT
                        </button>
                        <a asp-page="Index" class="btn btn-outline-secondary px-4 fw-bold d-flex align-items-center">
                            HỦY BỎ
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </main>

    <footer class="admin-footer d-flex justify-content-between">
        <div>&copy; 2026 <strong>MACVILLA</strong>. CMS System.</div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>