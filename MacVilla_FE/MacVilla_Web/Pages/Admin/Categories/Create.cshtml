@page
@model MacVilla_Web.Pages.Admin.Categories.CreateModel
@{
    ViewData["Title"] = "Thêm danh mục";
}

<h1 class="admin-page-title mb-4">Thêm danh mục mới</h1>

<div class="row justify-content-start">
    <div class="col-lg-6">
        <div class="admin-card">
            <div class="admin-card-header">Thông tin danh mục</div>
            <div class="admin-card-body admin-form">
                    <form method="post">
                        <div class="mb-3">
                            <label asp-for="CreateRequest.CategoryName" class="form-label">Tên danh mục <span class="text-danger">*</span></label>
                            <input asp-for="CreateRequest.CategoryName" class="form-control" placeholder="Nhập tên danh mục" required />
                            <span asp-validation-for="CreateRequest.CategoryName" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="CreateRequest.ParentCategoryId" class="form-label">Danh mục cha</label>
                            <select asp-for="CreateRequest.ParentCategoryId" class="form-select">
                                <option value="">-- Không có (danh mục gốc) --</option>
                                @if (Model.ParentCategories != null)
                                {
                                    @foreach (var c in Model.ParentCategories)
                                    {
                                        <option value="@c.CategoryId">@c.CategoryName</option>
                                    }
                                }
                            </select>
                        </div>
                        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                        {
                            <div class="alert alert-danger">@Model.ErrorMessage</div>
                        }
                        <div class="d-flex gap-2">
                <button type="submit" class="btn btn-admin-primary">Tạo mới</button>
                <a asp-page="Index" class="btn btn-admin-outline">Hủy</a>
            </div>
        </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
