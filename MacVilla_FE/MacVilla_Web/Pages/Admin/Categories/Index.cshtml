@page "/Admin/Categories"
@{
    Layout = "_AdminLayout"; ViewData["Title"] = "Danh mục";
}

<div class="mv-page-header d-flex justify-content-between align-items-start">
    <div><h1>Quản lý danh mục</h1><p>Quản lý cấu trúc danh mục sản phẩm</p></div>
    <button onclick="openModal('createModal')" class="btn-primary-mv" style="display:flex;align-items:center;gap:6px;border:none;cursor:pointer;">
        <i class="bi bi-plus-lg"></i> Thêm danh mục
    </button>
</div>

<!-- Search -->
<div class="search-bar">
    <div class="form-group" style="flex:2;">
        <label class="form-label-mv">Tên danh mục</label>
        <input type="text" id="f-name" class="form-control-mv" placeholder="Tìm kiếm...">
    </div>
    <div class="form-group" style="flex:1;">
        <label class="form-label-mv">Trạng thái</label>
        <select id="f-active" class="form-select-mv">
            <option value="">Tất cả</option>
            <option value="true">Đang hoạt động</option>
            <option value="false">Vô hiệu hóa</option>
        </select>
    </div>
    <div class="form-group" style="flex-direction:row;align-items:flex-end;gap:8px;">
        <button onclick="loadCats(1)" class="btn-primary-mv"><i class="bi bi-search"></i> Tìm</button>
        <button onclick="resetFilter()" class="btn-outline-mv">Đặt lại</button>
    </div>
</div>

<div class="mv-card">
    <div class="mv-card-header">
        <h5>Danh sách danh mục</h5>
        <span id="totalCount" style="font-size:.8rem;color:#6b7280;"></span>
    </div>
    <div style="overflow-x:auto;">
        <table class="mv-table">
            <thead>
                <tr>
                    <th>#ID</th>
                    <th>Tên danh mục</th>
                    <th>Danh mục cha</th>
                    <th>Trạng thái</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody id="catBody"><tr><td colspan="5" style="text-align:center;padding:32px;color:#9ca3af;">Đang tải...</td></tr></tbody>
        </table>
    </div>
    <div style="padding:16px 20px;border-top:1px solid #f3f4f6;">
        <div class="mv-pagination" id="pagination"></div>
    </div>
</div>

<!-- Create Modal -->
<div class="mv-modal-overlay" id="createModal">
    <div class="mv-modal">
        <div class="mv-modal-header"><h5>Thêm danh mục mới</h5><button class="btn-close-mv" onclick="closeModal('createModal')">&times;</button></div>
        <div class="mv-modal-body" style="display:flex;flex-direction:column;gap:14px;">
            <div>
                <label class="form-label-mv">Tên danh mục <span style="color:red;">*</span></label>
                <input type="text" id="c-name" class="form-control-mv" placeholder="Nhập tên danh mục...">
            </div>
            <div>
                <label class="form-label-mv">Danh mục cha (tuỳ chọn)</label>
                <select id="c-parent" class="form-select-mv"><option value="">-- Không có --</option></select>
            </div>
        </div>
        <div class="mv-modal-footer">
            <button class="btn btn-sm btn-outline-secondary px-4" onclick="closeModal('createModal')">Huỷ</button>
            <button class="btn btn-sm btn-success px-4" onclick="doCreate()">Thêm</button>
        </div>
    </div>
</div>

<!-- Edit Modal -->
<div class="mv-modal-overlay" id="editModal">
    <div class="mv-modal">
        <div class="mv-modal-header"><h5>Chỉnh sửa danh mục</h5><button class="btn-close-mv" onclick="closeModal('editModal')">&times;</button></div>
        <div class="mv-modal-body" style="display:flex;flex-direction:column;gap:14px;">
            <input type="hidden" id="e-id">
            <div>
                <label class="form-label-mv">Tên danh mục <span style="color:red;">*</span></label>
                <input type="text" id="e-name" class="form-control-mv">
            </div>
            <div>
                <label class="form-label-mv">Danh mục cha</label>
                <select id="e-parent" class="form-select-mv"><option value="">-- Không có --</option></select>
            </div>
        </div>
        <div class="mv-modal-footer">
            <button class="btn btn-sm btn-outline-secondary px-4" onclick="closeModal('editModal')">Huỷ</button>
            <button class="btn btn-sm btn-success px-4" onclick="doEdit()">Lưu</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let currentPage = 1;
        let allCats = [];

        async function loadAllCats() {
            const r = await apiFetch('/api/admin/category/getall');
            allCats = await r.json();
            ['c-parent','e-parent'].forEach(id => {
                const sel = document.getElementById(id);
                sel.innerHTML = '<option value="">-- Không có --</option>';
                allCats.forEach(c => sel.innerHTML += `<option value="${c.CategoryId}">${c.Name}</option>`);
            });
        }

        async function loadCats(page = 1) {
            currentPage = page;
            const name = document.getElementById('f-name').value;
            const isActive = document.getElementById('f-active').value;
            const params = new URLSearchParams({ PageNumber: page, PageSize: 15, ...(name&&{Name:name}), ...(isActive!==''&&{IsActive:isActive}) });
            document.getElementById('catBody').innerHTML = '<tr><td colspan="5" style="text-align:center;padding:32px;color:#9ca3af;">Đang tải...</td></tr>';
            try {
                const r = await apiFetch('/api/admin/category?' + params);
                const data = await r.json();
                document.getElementById('totalCount').textContent = `${data.TotalCount||0} danh mục`;
                const items = data.Data || [];
                if (!items.length) {
                    document.getElementById('catBody').innerHTML = '<tr><td colspan="5" style="text-align:center;padding:32px;color:#9ca3af;">Không tìm thấy</td></tr>';
                } else {
                    document.getElementById('catBody').innerHTML = items.map(c => {
                        const parent = allCats.find(a => a.CategoryId === c.ParentCategoryId);
                        return `<tr>
                            <td style="color:#9ca3af;font-size:.8rem;">#${c.CategoryId}</td>
                            <td style="font-weight:500;">${c.CategoryName||''}</td>
                            <td style="color:#6b7280;font-size:.85rem;">${parent ? parent.Name : '<span style="color:#d1d5db;">—</span>'}</td>
                            <td><span class="badge-status ${c.IsActive?'badge-active':'badge-disable'}">${c.IsActive?'Hoạt động':'Vô hiệu'}</span></td>
                            <td>
                                <div style="display:flex;gap:6px;">
                                    <button onclick="openEdit(${c.CategoryId})" style="width:30px;height:30px;display:flex;align-items:center;justify-content:center;border:1px solid #e5e7eb;border-radius:6px;background:transparent;color:#374151;cursor:pointer;font-size:.85rem;"><i class="bi bi-pencil"></i></button>
                                    <button onclick="toggleActive(${c.CategoryId},${c.IsActive})" title="${c.IsActive?'Vô hiệu hóa':'Kích hoạt'}" style="width:30px;height:30px;display:flex;align-items:center;justify-content:center;border:1px solid ${c.IsActive?'#fee2e2':'#dcfce7'};border-radius:6px;background:transparent;color:${c.IsActive?'#dc2626':'#15803d'};cursor:pointer;font-size:.85rem;">
                                        <i class="bi ${c.IsActive?'bi-toggle-on':'bi-toggle-off'}"></i>
                                    </button>
                                    <button onclick="deleteCat(${c.CategoryId},'${(c.CategoryName||'').replace(/'/g,"\\'")}')" style="width:30px;height:30px;display:flex;align-items:center;justify-content:center;border:1px solid #fee2e2;border-radius:6px;background:transparent;color:#dc2626;cursor:pointer;font-size:.85rem;"><i class="bi bi-trash"></i></button>
                                </div>
                            </td>
                        </tr>`;
                    }).join('');
                }
                const total = data.TotalPages || 1;
                let html = '';
                if (page > 1) html += `<a onclick="loadCats(${page-1})" href="#">‹</a>`;
                for (let i = Math.max(1,page-2); i <= Math.min(total,page+2); i++) html += i===page ? `<span class="active">${i}</span>` : `<a onclick="loadCats(${i})" href="#">${i}</a>`;
                if (page < total) html += `<a onclick="loadCats(${page+1})" href="#">›</a>`;
                document.getElementById('pagination').innerHTML = html;
            } catch(e) { showToast('Lỗi tải danh mục', 'error'); }
        }

        function resetFilter() { document.getElementById('f-name').value=''; document.getElementById('f-active').value=''; loadCats(1); }

        async function doCreate() {
            const name = document.getElementById('c-name').value.trim();
            const parent = document.getElementById('c-parent').value;
            if (!name) { showToast('Vui lòng nhập tên danh mục', 'error'); return; }
            try {
                const r = await apiFetch('/api/admin/category', { method:'POST', body: JSON.stringify({ CategoryName: name, ParentCategoryId: parent || null }) });
                if (!r.ok) throw new Error((await r.json()).message);
                closeModal('createModal');
                document.getElementById('c-name').value = '';
                showToast('Thêm danh mục thành công', 'success');
                await loadAllCats(); loadCats(1);
            } catch(e) { showToast(e.message, 'error'); }
        }

        function openEdit(id) {
            const cat = allCats.find(c => c.CategoryId === id);
            if (!cat) return;
            document.getElementById('e-id').value = id;
            document.getElementById('e-name').value = cat.Name || '';
            document.getElementById('e-parent').value = '';
            openModal('editModal');
            apiFetch(`/api/admin/category/${id}`).then(r => r.json()).then(c => {
                document.getElementById('e-parent').value = c.ParentCategoryId || '';
            });
        }

        async function doEdit() {
            const id = document.getElementById('e-id').value;
            const name = document.getElementById('e-name').value.trim();
            const parent = document.getElementById('e-parent').value;
            if (!name) { showToast('Vui lòng nhập tên danh mục', 'error'); return; }
            try {
                const r = await apiFetch(`/api/admin/category/${id}`, { method:'PUT', body: JSON.stringify({ CategoryName: name, ParentCategoryId: parent || null }) });
                if (!r.ok) throw new Error((await r.json()).message);
                closeModal('editModal');
                showToast('Cập nhật thành công', 'success');
                await loadAllCats(); loadCats(currentPage);
            } catch(e) { showToast(e.message, 'error'); }
        }

        async function toggleActive(id, current) {
            const endpoint = current ? 'deactivate' : 'activate';
            try {
                const r = await apiFetch(`/api/admin/category/${id}/${endpoint}`, { method:'PATCH' });
                if (!r.ok) throw new Error((await r.json()).message);
                showToast(`Đã ${current?'vô hiệu hóa':'kích hoạt'} danh mục`, 'success');
                loadCats(currentPage);
            } catch(e) { showToast(e.message, 'error'); }
        }

        async function deleteCat(id, name) {
            confirmModal('Xác nhận xoá', `Bạn chắc chắn muốn xoá danh mục <strong>${name}</strong>?`, async () => {
                try {
                    const r = await apiFetch(`/api/admin/category/${id}`, { method:'DELETE' });
                    if (!r.ok) throw new Error((await r.json()).message);
                    showToast('Đã xoá danh mục', 'success');
                    await loadAllCats(); loadCats(currentPage);
                } catch(e) { showToast(e.message, 'error'); }
            });
        }

        loadAllCats().then(() => loadCats(1));
    </script>
}
