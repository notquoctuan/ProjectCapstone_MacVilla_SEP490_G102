@page
@model MacVilla_Web.Pages.Admin.Categories.IndexModel
@{
    ViewData["Title"] = "Quản lý danh mục";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="admin-page-title mb-0">Quản lý danh mục</h1>
    <a asp-page="Create" class="btn btn-admin-primary">+ Thêm danh mục</a>
</div>

<div class="admin-card mb-4">
    <div class="admin-card-body">
            <form method="get" class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Tên danh mục</label>
                    <input asp-for="SearchRequest.Name" class="form-control" placeholder="Nhập tên để tìm kiếm..." />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Trạng thái</label>
                    <select asp-for="SearchRequest.IsActive" class="form-select">
                        <option value="">Tất cả</option>
                        <option value="true">Đang hoạt động</option>
                        <option value="false">Ngừng hoạt động</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Số dòng/trang</label>
                    <select asp-for="SearchRequest.PageSize" class="form-select">
                        <option value="5">5</option>
                        <option value="10">10</option>
                        <option value="20">20</option>
                        <option value="50">50</option>
                    </select>
                </div>
                <div class="col-md-3 d-flex align-items-end gap-2">
                    <button type="submit" class="btn btn-admin-primary">Tìm kiếm</button>
                    <a asp-page="Index" class="btn btn-admin-outline">Xóa bộ lọc</a>
                </div>
            </form>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert alert-dismissible fade show admin-alert-success" role="alert">
        @Model.Message
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="admin-card">
    <div class="admin-card-body">
        <div class="table-responsive">
            <table class="table table-hover admin-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Tên danh mục</th>
                            <th>Danh mục cha</th>
                            <th>Trạng thái</th>
                            <th width="200">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.PagedResult?.Data != null && Model.PagedResult.Data.Any())
                        {
                            @foreach (var item in Model.PagedResult.Data)
                            {
                                <tr>
                                    <td>@item.CategoryId</td>
                                    <td>@item.CategoryName</td>
                                    <td>@(item.ParentCategoryId.HasValue ? item.ParentCategoryId.ToString() : "-")</td>
                                    <td>
                                        @if (item.IsActive == true)
                                        {
                                            <span class="badge bg-success">Hoạt động</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Ngừng</span>
                                        }
                                    </td>
                                    <td>
                                        <a asp-page="Edit" asp-route-id="@item.CategoryId" class="btn btn-sm btn-admin-outline">Sửa</a>
                                        @if (item.IsActive == true)
                                        {
                                            <form asp-page-handler="Deactivate" asp-route-id="@item.CategoryId" method="post" class="d-inline">
                                                <input type="hidden" asp-for="SearchRequest.Name" />
                                                <input type="hidden" asp-for="SearchRequest.IsActive" />
                                                <input type="hidden" asp-for="SearchRequest.PageNumber" />
                                                <input type="hidden" asp-for="SearchRequest.PageSize" />
                                                <button type="submit" class="btn btn-sm btn-admin-outline" onclick="return confirm('Bạn có chắc muốn ngừng hoạt động danh mục này?')">Ngừng</button>
                                            </form>
                                        }
                                        else
                                        {
                                            <form asp-page-handler="Activate" asp-route-id="@item.CategoryId" method="post" class="d-inline">
                                                <input type="hidden" asp-for="SearchRequest.Name" />
                                                <input type="hidden" asp-for="SearchRequest.IsActive" />
                                                <input type="hidden" asp-for="SearchRequest.PageNumber" />
                                                <input type="hidden" asp-for="SearchRequest.PageSize" />
                                                <button type="submit" class="btn btn-sm btn-admin-outline">Kích hoạt</button>
                                            </form>
                                        }
                                        <form asp-page-handler="Delete" asp-route-id="@item.CategoryId" method="post" class="d-inline">
                                            <input type="hidden" asp-for="SearchRequest.Name" />
                                            <input type="hidden" asp-for="SearchRequest.IsActive" />
                                            <input type="hidden" asp-for="SearchRequest.PageNumber" />
                                            <input type="hidden" asp-for="SearchRequest.PageSize" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Bạn có chắc muốn xóa danh mục này?')">Xóa</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-4">Không có dữ liệu</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (Model.PagedResult != null && Model.PagedResult.TotalPages > 1 && Model.PagedResult.TotalCount > 0)
            {
                <nav class="mt-3">
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(Model.SearchRequest.PageNumber <= 1 ? "disabled" : "")">
                            <a class="page-link" asp-page="Index" asp-all-route-data="Model.GetPageRouteData(Model.SearchRequest.PageNumber - 1)">Trước</a>
                        </li>
                        @for (var i = 1; i <= Model.PagedResult.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.SearchRequest.PageNumber ? "active" : "")">
                                <a class="page-link" asp-page="Index" asp-all-route-data="Model.GetPageRouteData(i)">@i</a>
                            </li>
                        }
                        <li class="page-item @(Model.SearchRequest.PageNumber >= Model.PagedResult.TotalPages ? "disabled" : "")">
                            <a class="page-link" asp-page="Index" asp-all-route-data="Model.GetPageRouteData(Model.SearchRequest.PageNumber + 1)">Sau</a>
                        </li>
                    </ul>
                </nav>
            }
        </div>
    </div>
</div>
