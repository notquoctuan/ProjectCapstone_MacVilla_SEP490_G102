@page "/Admin/Orders/Detail/{id:long}"
@{
    Layout = "_AdminLayout"; ViewData["Title"] = "Chi tiết đơn hàng";
}

<div class="mv-page-header d-flex justify-content-between align-items-start">
    <div><h1 id="pageTitle">Chi tiết đơn hàng</h1><p>Thông tin đầy đủ về đơn hàng</p></div>
    <a href="/Admin/Orders" class="btn-outline-mv" style="text-decoration:none;display:flex;align-items:center;gap:6px;"><i class="bi bi-arrow-left"></i> Quay lại</a>
</div>

<div style="display:grid;grid-template-columns:1fr 340px;gap:20px;">
    <!-- Left -->
    <div style="display:flex;flex-direction:column;gap:16px;">
        <!-- Order items -->
        <div class="mv-card">
            <div class="mv-card-header"><h5>Sản phẩm trong đơn</h5></div>
            <div id="orderItems"><div style="padding:24px;text-align:center;color:#9ca3af;">Đang tải...</div></div>
        </div>
        <!-- Customer -->
        <div class="mv-card">
            <div class="mv-card-header"><h5>Thông tin khách hàng</h5></div>
            <div class="mv-card-body" id="customerInfo"><div style="color:#9ca3af;">Đang tải...</div></div>
        </div>
        <!-- Shipping -->
        <div class="mv-card">
            <div class="mv-card-header"><h5>Thông tin vận chuyển</h5></div>
            <div class="mv-card-body" id="shippingInfo"><div style="color:#9ca3af;">Đang tải...</div></div>
        </div>
        <!-- Payment -->
        <div class="mv-card">
            <div class="mv-card-header"><h5>Thanh toán</h5></div>
            <div class="mv-card-body" id="paymentInfo"><div style="color:#9ca3af;">Đang tải...</div></div>
        </div>
    </div>

    <!-- Right -->
    <div style="display:flex;flex-direction:column;gap:16px;">
        <div class="mv-card">
            <div class="mv-card-header"><h5>Tóm tắt đơn hàng</h5></div>
            <div class="mv-card-body" id="orderSummary"><div style="color:#9ca3af;">Đang tải...</div></div>
        </div>
        <div class="mv-card" id="actionCard" style="display:none;">
            <div class="mv-card-header"><h5>Cập nhật trạng thái</h5></div>
            <div class="mv-card-body" style="display:flex;flex-direction:column;gap:10px;">
                <select id="newStatus" class="form-select-mv">
                    <option value="Processing">Processing</option>
                    <option value="Shipped">Shipped</option>
                    <option value="Completed">Completed</option>
                    <option value="Cancelled">Cancelled</option>
                </select>
                <button onclick="doUpdateStatus()" class="btn-primary-mv w-100">Cập nhật</button>
                <button onclick="doCancelOrder()" class="btn btn-outline-danger w-100 btn-sm" id="btnCancel" style="display:none;">Huỷ đơn hàng</button>
            </div>
        </div>
        <!-- Tracking timeline -->
        <div class="mv-card">
            <div class="mv-card-header"><h5>Tracking</h5></div>
            <div class="mv-card-body" id="trackingTimeline"><div style="color:#9ca3af;">Đang tải...</div></div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const orderId = parseInt(location.pathname.split('/').pop());
        const statusMap = { Pending:'badge-pending', Processing:'badge-processing', Shipped:'badge-shipped', Completed:'badge-completed', Cancelled:'badge-cancelled' };

        async function loadOrder() {
            try {
                const [dRes, tRes] = await Promise.all([
                    apiFetch(`/api/admin/order/${orderId}`),
                    apiFetch(`/api/admin/order/${orderId}/tracking`)
                ]);
                const order = await dRes.json();
                const tracking = await tRes.json();

                document.getElementById('pageTitle').textContent = `Đơn hàng #${order.OrderId}`;

                // Summary
                const date = order.CreatedAt ? new Date(order.CreatedAt).toLocaleString('vi-VN') : '---';
                document.getElementById('orderSummary').innerHTML = `
                    <div style="display:flex;flex-direction:column;gap:10px;font-size:.875rem;">
                        <div style="display:flex;justify-content:space-between;"><span style="color:#6b7280;">Mã đơn</span><strong>#${order.OrderId}</strong></div>
                        <div style="display:flex;justify-content:space-between;"><span style="color:#6b7280;">Ngày tạo</span><span>${date}</span></div>
                        <div style="display:flex;justify-content:space-between;"><span style="color:#6b7280;">Trạng thái</span><span class="badge-status ${statusMap[order.Status]||'badge-pending'}">${order.Status}</span></div>
                        <div style="border-top:1px solid #f3f4f6;padding-top:10px;display:flex;justify-content:space-between;"><span style="color:#6b7280;">Tổng cộng</span><strong style="color:#2E7D32;font-size:1rem;">${(order.TotalAmount||0).toLocaleString('vi-VN')}đ</strong></div>
                    </div>`;

                // Action card
                if (order.Status !== 'Completed' && order.Status !== 'Cancelled') {
                    document.getElementById('actionCard').style.display = '';
                    if (order.Status === 'Pending') document.getElementById('btnCancel').style.display = '';
                }

                // Customer
                const c = order.Customer;
                document.getElementById('customerInfo').innerHTML = c ? `
                    <div style="display:flex;flex-direction:column;gap:8px;font-size:.875rem;">
                        <div style="display:flex;gap:8px;"><span style="color:#6b7280;width:80px;">Họ tên</span><strong>${c.FullName||'---'}</strong></div>
                        <div style="display:flex;gap:8px;"><span style="color:#6b7280;width:80px;">Email</span><span>${c.Email||'---'}</span></div>
                        <div style="display:flex;gap:8px;"><span style="color:#6b7280;width:80px;">SĐT</span><span>${c.Phone||'---'}</span></div>
                    </div>` : '<p style="color:#9ca3af;">Không có thông tin</p>';

                // Items
                const items = order.OrderItems || [];
                document.getElementById('orderItems').innerHTML = items.length ? `
                    <table class="mv-table">
                        <thead><tr><th>Sản phẩm</th><th>SL</th><th>Đơn giá</th><th>Thành tiền</th></tr></thead>
                        <tbody>${items.map(i => `<tr>
                            <td><div style="display:flex;align-items:center;gap:10px;">
                                ${i.ProductImageUrl ? `<img src="https://localhost:7262${i.ProductImageUrl}" class="img-thumb">` : '<div style="width:56px;height:56px;background:#f3f4f6;border-radius:8px;"></div>'}
                                <div><div style="font-weight:500;">${i.ProductName||'---'}</div><div style="font-size:.75rem;color:#9ca3af;">${i.CategoryName||''}</div></div>
                            </div></td>
                            <td>${i.Quantity||0}</td>
                            <td>${(i.UnitPrice||0).toLocaleString('vi-VN')}đ</td>
                            <td style="font-weight:600;">${(i.SubTotal||0).toLocaleString('vi-VN')}đ</td>
                        </tr>`).join('')}</tbody>
                    </table>` : '<div style="padding:24px;text-align:center;color:#9ca3af;">Không có sản phẩm</div>';

                // Shipping
                const ships = order.Shippings || [];
                document.getElementById('shippingInfo').innerHTML = ships.length ? ships.map(s => {
                    const addr = s.ShippingAddress;
                    const method = s.ShippingMethod;
                    return `<div style="font-size:.875rem;display:flex;flex-direction:column;gap:8px;">
                        ${addr ? `<div style="background:#f9fafb;padding:12px;border-radius:8px;">
                            <div style="font-weight:600;margin-bottom:6px;">${addr.ReceiverName||''} — ${addr.Phone||''}</div>
                            <div style="color:#6b7280;">${[addr.AddressLine,addr.Ward,addr.District,addr.City].filter(Boolean).join(', ')}</div>
                        </div>` : ''}
                        ${method ? `<div><span style="color:#6b7280;">Phương thức:</span> ${method.MethodName||''} — ${method.EstimatedDays||''} ngày — <strong>${(method.BaseFee||0).toLocaleString('vi-VN')}đ</strong></div>` : ''}
                        <div><span style="color:#6b7280;">Trạng thái vận chuyển:</span> ${s.Status||'---'}</div>
                    </div>`;
                }).join('<hr style="margin:10px 0;">') : '<p style="color:#9ca3af;">Chưa có thông tin vận chuyển</p>';

                // Payment
                const pays = order.Payments || [];
                document.getElementById('paymentInfo').innerHTML = pays.length ? `
                    <table class="mv-table">
                        <thead><tr><th>#</th><th>Phương thức</th><th>Trạng thái</th><th>Thời gian</th></tr></thead>
                        <tbody>${pays.map(p => `<tr>
                            <td style="color:#9ca3af;">#${p.PaymentId}</td>
                            <td>${p.PaymentMethod||'---'}</td>
                            <td>${p.PaymentStatus||'---'}</td>
                            <td style="font-size:.8rem;color:#9ca3af;">${p.PaidAt ? new Date(p.PaidAt).toLocaleString('vi-VN') : '---'}</td>
                        </tr>`).join('')}</tbody>
                    </table>` : '<p style="color:#9ca3af;">Chưa có thông tin thanh toán</p>';

                // Tracking
                const tl = tracking?.Timeline;
                if (tl) {
                    const steps = [
                        { label: 'Đã đặt hàng', done: tl.IsOrderPlaced, time: tl.OrderPlacedAt },
                        { label: 'Đã thanh toán', done: tl.IsPaymentReceived, time: tl.PaymentReceivedAt },
                        { label: 'Đang xử lý', done: tl.IsProcessing, time: tl.ProcessingStartedAt },
                        { label: 'Đã giao vận chuyển', done: tl.IsShipped, time: tl.ShippedAt },
                        { label: 'Đã giao hàng', done: tl.IsDelivered, time: tl.DeliveredAt },
                    ];
                    if (tl.IsCancelled) steps.push({ label: 'Đã huỷ', done: true, time: null, cancelled: true });
                    document.getElementById('trackingTimeline').innerHTML = `
                        <div style="display:flex;flex-direction:column;gap:0;">
                            ${steps.map((s,i) => `<div style="display:flex;align-items:flex-start;gap:14px;${i<steps.length-1?'padding-bottom:16px;':''}">
                                <div style="display:flex;flex-direction:column;align-items:center;flex-shrink:0;">
                                    <div style="width:28px;height:28px;border-radius:50%;background:${s.cancelled?'#fee2e2':s.done?'#dcfce7':'#f3f4f6'};border:2px solid ${s.cancelled?'#dc2626':s.done?'#15803d':'#d1d5db'};display:flex;align-items:center;justify-content:center;font-size:.8rem;">
                                        ${s.cancelled ? '✕' : s.done ? '✓' : '○'}
                                    </div>
                                    ${i<steps.length-1 ? `<div style="width:2px;background:${s.done?'#4CAF50':'#e5e7eb'};flex:1;min-height:20px;margin-top:2px;"></div>` : ''}
                                </div>
                                <div style="padding-top:4px;">
                                    <div style="font-size:.875rem;font-weight:${s.done?'600':'400'};color:${s.done?(s.cancelled?'#dc2626':'#1a1a2e'):'#9ca3af'};">${s.label}</div>
                                    ${s.time ? `<div style="font-size:.75rem;color:#9ca3af;">${new Date(s.time).toLocaleString('vi-VN')}</div>` : ''}
                                </div>
                            </div>`).join('')}
                        </div>`;
                }
            } catch(e) { showToast('Lỗi tải đơn hàng: ' + e.message, 'error'); }
        }

        async function doUpdateStatus() {
            const status = document.getElementById('newStatus').value;
            try {
                const r = await apiFetch(`/api/admin/order/${orderId}/status`, { method:'PUT', body: JSON.stringify({ Status: status }) });
                const data = await r.json();
                if (!r.ok) throw new Error(data.message);
                showToast('Cập nhật trạng thái thành công', 'success');
                setTimeout(() => loadOrder(), 800);
            } catch(e) { showToast(e.message, 'error'); }
        }

        async function doCancelOrder() {
            confirmModal('Huỷ đơn hàng', `Bạn có chắc muốn huỷ đơn hàng <strong>#${orderId}</strong>?`, async () => {
                try {
                    const r = await apiFetch(`/api/admin/order/${orderId}/cancel`, { method:'POST', body: JSON.stringify({}) });
                    if (!r.ok) throw new Error((await r.json()).message);
                    showToast('Đã huỷ đơn hàng', 'success');
                    setTimeout(() => loadOrder(), 800);
                } catch(e) { showToast(e.message, 'error'); }
            });
        }

        loadOrder();
    </script>
}
