@page "/Admin/Orders"
@{
    Layout = "_AdminLayout"; ViewData["Title"] = "Đơn hàng";
}

<div class="mv-page-header">
    <h1>Quản lý đơn hàng</h1>
    <p>Theo dõi và cập nhật trạng thái đơn hàng</p>
</div>

<div class="search-bar">
    <div class="form-group" style="flex:1;min-width:120px;">
        <label class="form-label-mv">Trạng thái</label>
        <select id="f-status" class="form-select-mv">
            <option value="">Tất cả</option>
            <option value="Pending">Pending</option>
            <option value="Processing">Processing</option>
            <option value="Shipped">Shipped</option>
            <option value="Completed">Completed</option>
            <option value="Cancelled">Cancelled</option>
        </select>
    </div>
    <div class="form-group" style="flex:1;min-width:140px;">
        <label class="form-label-mv">Từ ngày</label>
        <input type="date" id="f-from" class="form-control-mv">
    </div>
    <div class="form-group" style="flex:1;min-width:140px;">
        <label class="form-label-mv">Đến ngày</label>
        <input type="date" id="f-to" class="form-control-mv">
    </div>
    <div class="form-group" style="flex-direction:row;align-items:flex-end;gap:8px;">
        <button onclick="loadOrders(1)" class="btn-primary-mv"><i class="bi bi-search"></i> Tìm</button>
        <button onclick="resetFilter()" class="btn-outline-mv">Đặt lại</button>
    </div>
</div>

<div class="mv-card">
    <div class="mv-card-header">
        <h5>Danh sách đơn hàng</h5>
        <span id="totalCount" style="font-size:.8rem;color:#6b7280;"></span>
    </div>
    <div style="overflow-x:auto;">
        <table class="mv-table">
            <thead>
                <tr><th>#ID</th><th>Khách hàng</th><th>Tổng tiền</th><th>T.Toán</th><th>Vận chuyển</th><th>Trạng thái</th><th>Ngày tạo</th><th>Thao tác</th></tr>
            </thead>
            <tbody id="orderBody"><tr><td colspan="8" style="text-align:center;padding:32px;color:#9ca3af;">Đang tải...</td></tr></tbody>
        </table>
    </div>
    <div style="padding:16px 20px;border-top:1px solid #f3f4f6;">
        <div class="mv-pagination" id="pagination"></div>
    </div>
</div>

<!-- Status modal -->
<div class="mv-modal-overlay" id="statusModal">
    <div class="mv-modal">
        <div class="mv-modal-header"><h5>Cập nhật trạng thái đơn</h5><button class="btn-close-mv" onclick="closeModal('statusModal')">&times;</button></div>
        <div class="mv-modal-body" style="display:flex;flex-direction:column;gap:12px;">
            <input type="hidden" id="sm-id">
            <div id="sm-info" style="background:#f9fafb;border-radius:8px;padding:12px;font-size:.85rem;"></div>
            <div>
                <label class="form-label-mv">Trạng thái mới</label>
                <select id="sm-status" class="form-select-mv">
                    <option value="Processing">Processing</option>
                    <option value="Shipped">Shipped</option>
                    <option value="Completed">Completed</option>
                    <option value="Cancelled">Cancelled</option>
                </select>
            </div>
            <div style="background:#fef3c7;border-radius:8px;padding:10px;font-size:.78rem;color:#92400e;">
                <strong>Lưu ý luồng trạng thái:</strong><br>
                Pending → Processing → Shipped → Completed<br>
                Pending / Processing / Shipped → Cancelled
            </div>
        </div>
        <div class="mv-modal-footer">
            <button class="btn btn-sm btn-outline-secondary px-4" onclick="closeModal('statusModal')">Huỷ</button>
            <button class="btn btn-sm btn-success px-4" onclick="doUpdateStatus()">Cập nhật</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let currentPage = 1;
        const statusMap = { Pending:'badge-pending', Processing:'badge-processing', Shipped:'badge-shipped', Completed:'badge-completed', Cancelled:'badge-cancelled' };

        async function loadOrders(page = 1) {
            currentPage = page;
            const status = document.getElementById('f-status').value;
            const from = document.getElementById('f-from').value;
            const to = document.getElementById('f-to').value;
            const params = new URLSearchParams({ PageNumber: page, PageSize: 15, ...(status&&{Status:status}), ...(from&&{StartDate:from}), ...(to&&{EndDate:to}) });
            document.getElementById('orderBody').innerHTML = '<tr><td colspan="8" style="text-align:center;padding:32px;color:#9ca3af;">Đang tải...</td></tr>';
            try {
                const r = await apiFetch('/api/admin/order?' + params);
                const data = await r.json();
                document.getElementById('totalCount').textContent = `${data.TotalCount||0} đơn hàng`;
                const items = data.Data || [];
                if (!items.length) {
                    document.getElementById('orderBody').innerHTML = '<tr><td colspan="8" style="text-align:center;padding:32px;color:#9ca3af;">Không tìm thấy đơn hàng nào</td></tr>';
                } else {
                    document.getElementById('orderBody').innerHTML = items.map(o => {
                        const date = o.CreatedAt ? new Date(o.CreatedAt).toLocaleDateString('vi-VN') : '---';
                        return `<tr>
                            <td><a href="/Admin/Orders/Detail/${o.OrderId}" style="color:#2E7D32;font-weight:600;text-decoration:none;">#${o.OrderId}</a></td>
                            <td><div style="font-weight:500;font-size:.875rem;">${o.CustomerName||'---'}</div><div style="font-size:.75rem;color:#9ca3af;">${o.CustomerEmail||''}</div></td>
                            <td style="font-weight:600;">${(o.TotalAmount||0).toLocaleString('vi-VN')}đ</td>
                            <td><span style="font-size:.78rem;color:#6b7280;">${o.PaymentStatus||'---'}</span></td>
                            <td><span style="font-size:.78rem;color:#6b7280;">${o.ShippingStatus||'---'}</span></td>
                            <td><span class="badge-status ${statusMap[o.Status]||'badge-pending'}">${o.Status}</span></td>
                            <td style="color:#9ca3af;font-size:.8rem;">${date}</td>
                            <td>
                                <div style="display:flex;gap:6px;">
                                    <a href="/Admin/Orders/Detail/${o.OrderId}" title="Xem chi tiết" style="width:30px;height:30px;display:flex;align-items:center;justify-content:center;border:1px solid #e5e7eb;border-radius:6px;color:#374151;text-decoration:none;font-size:.85rem;"><i class="bi bi-eye"></i></a>
                                    ${o.Status!=='Completed'&&o.Status!=='Cancelled' ? `<button onclick="openStatusModal(${o.OrderId},'${o.Status}')" title="Đổi trạng thái" style="width:30px;height:30px;display:flex;align-items:center;justify-content:center;border:1px solid #dbeafe;border-radius:6px;background:transparent;color:#1d4ed8;cursor:pointer;font-size:.85rem;"><i class="bi bi-arrow-repeat"></i></button>` : ''}
                                    ${o.Status==='Pending' ? `<button onclick="cancelOrder(${o.OrderId})" title="Huỷ đơn" style="width:30px;height:30px;display:flex;align-items:center;justify-content:center;border:1px solid #fee2e2;border-radius:6px;background:transparent;color:#dc2626;cursor:pointer;font-size:.85rem;"><i class="bi bi-x-circle"></i></button>` : ''}
                                </div>
                            </td>
                        </tr>`;
                    }).join('');
                }
                const total = data.TotalPages || 1;
                let html = '';
                if (page > 1) html += `<a onclick="loadOrders(${page-1})" href="#">‹</a>`;
                for (let i = Math.max(1,page-2); i <= Math.min(total,page+2); i++) html += i===page ? `<span class="active">${i}</span>` : `<a onclick="loadOrders(${i})" href="#">${i}</a>`;
                if (page < total) html += `<a onclick="loadOrders(${page+1})" href="#">›</a>`;
                document.getElementById('pagination').innerHTML = html;
            } catch(e) { showToast('Lỗi tải đơn hàng', 'error'); }
        }

        function resetFilter() { ['f-status','f-from','f-to'].forEach(id => document.getElementById(id).value=''); loadOrders(1); }

        function openStatusModal(id, status) {
            document.getElementById('sm-id').value = id;
            document.getElementById('sm-info').innerHTML = `Đơn hàng <strong>#${id}</strong> — Trạng thái hiện tại: <span class="badge-status ${statusMap[status]}">${status}</span>`;
            openModal('statusModal');
        }

        async function doUpdateStatus() {
            const id = document.getElementById('sm-id').value;
            const status = document.getElementById('sm-status').value;
            try {
                const r = await apiFetch(`/api/admin/order/${id}/status`, { method:'PUT', body: JSON.stringify({ Status: status }) });
                const data = await r.json();
                if (!r.ok) throw new Error(data.message);
                closeModal('statusModal');
                showToast('Cập nhật trạng thái thành công', 'success');
                loadOrders(currentPage);
            } catch(e) { showToast(e.message, 'error'); }
        }

        async function cancelOrder(id) {
            confirmModal('Huỷ đơn hàng', `Bạn có chắc muốn huỷ đơn hàng <strong>#${id}</strong>?`, async () => {
                try {
                    const r = await apiFetch(`/api/admin/order/${id}/cancel`, { method:'POST', body: JSON.stringify({}) });
                    if (!r.ok) throw new Error((await r.json()).message);
                    showToast('Đã huỷ đơn hàng', 'success');
                    loadOrders(currentPage);
                } catch(e) { showToast(e.message, 'error'); }
            });
        }

        loadOrders(1);
    </script>
}
