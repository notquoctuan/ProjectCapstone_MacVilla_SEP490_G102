@page "/Admin/Dashboard"
@{
    Layout = "_AdminLayout"; ViewData["Title"] = "Tổng quan";
}

<div class="mv-page-header">
    <h1>Bảng điều khiển</h1>
    <p>Tổng quan hệ thống MacVilla</p>
</div>

<!-- Stat Cards -->
<div id="statCards" style="display:grid; grid-template-columns: repeat(4,1fr); gap:16px; margin-bottom:28px;">
    <div class="stat-card"><div class="stat-icon" style="background:#dcfce7;color:#15803d;"><i class="bi bi-box-seam"></i></div><div><div class="stat-val" id="s-products">--</div><div class="stat-label">Tổng sản phẩm</div></div></div>
    <div class="stat-card"><div class="stat-icon" style="background:#dbeafe;color:#1d4ed8;"><i class="bi bi-receipt-cutoff"></i></div><div><div class="stat-val" id="s-orders">--</div><div class="stat-label">Tổng đơn hàng</div></div></div>
    <div class="stat-card"><div class="stat-icon" style="background:#ede9fe;color:#7c3aed;"><i class="bi bi-people"></i></div><div><div class="stat-val" id="s-users">--</div><div class="stat-label">Khách hàng</div></div></div>
    <div class="stat-card"><div class="stat-icon" style="background:#fef3c7;color:#d97706;"><i class="bi bi-tags"></i></div><div><div class="stat-val" id="s-cats">--</div><div class="stat-label">Danh mục</div></div></div>
</div>

<div style="display:grid; grid-template-columns:1fr 1fr; gap:20px;">
    <!-- Recent Orders -->
    <div class="mv-card">
        <div class="mv-card-header">
            <h5><i class="bi bi-receipt-cutoff me-2" style="color:#2E7D32;"></i>Đơn hàng gần đây</h5>
            <a href="/Admin/Orders" style="font-size:.8rem;color:#2E7D32;text-decoration:none;">Xem tất cả →</a>
        </div>
        <div id="recentOrders" style="padding:0;">
            <div style="padding:24px;text-align:center;color:#9ca3af;font-size:.85rem;">Đang tải...</div>
        </div>
    </div>
    <!-- Recent Users -->
    <div class="mv-card">
        <div class="mv-card-header">
            <h5><i class="bi bi-person-plus me-2" style="color:#2E7D32;"></i>Người dùng mới</h5>
            <a href="/Admin/Users" style="font-size:.8rem;color:#2E7D32;text-decoration:none;">Xem tất cả →</a>
        </div>
        <div id="recentUsers" style="padding:0;">
            <div style="padding:24px;text-align:center;color:#9ca3af;font-size:.85rem;">Đang tải...</div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (async function() {
            if (!getToken()) { window.location.href = '/Auth/Login'; return; }
            const name = sessionStorage.getItem('userName') || 'Admin';
            document.querySelectorAll('.admin-name').forEach(el => el.innerHTML = `<i class="bi bi-person-circle me-1"></i> ${name}`);

            async function load() {
                try {
                    const [pRes, oRes, uRes, cRes] = await Promise.all([
                        apiFetch('/api/admin/products?PageSize=1'),
                        apiFetch('/api/admin/order?PageSize=1'),
                        apiFetch('/api/admin/users?PageSize=1'),
                        apiFetch('/api/admin/category?PageSize=1')
                    ]);
                    const [p, o, u, c] = await Promise.all([pRes.json(), oRes.json(), uRes.json(), cRes.json()]);
                    document.getElementById('s-products').textContent = p.TotalCount ?? '--';
                    document.getElementById('s-orders').textContent = o.TotalCount ?? '--';
                    document.getElementById('s-users').textContent = u.TotalCount ?? '--';
                    document.getElementById('s-cats').textContent = c.TotalCount ?? '--';
                } catch(e) { console.error(e); }

                try {
                    const oRes = await apiFetch('/api/admin/order?PageSize=8&SortOrder=newest');
                    const oData = await oRes.json();
                    const orders = oData.Data || [];
                    const statusMap = { Pending:'badge-pending', Processing:'badge-processing', Shipped:'badge-shipped', Completed:'badge-completed', Cancelled:'badge-cancelled' };
                    document.getElementById('recentOrders').innerHTML = orders.length ? `
                        <table class="mv-table">
                            <thead><tr><th>#ID</th><th>Khách hàng</th><th>Tổng tiền</th><th>Trạng thái</th></tr></thead>
                            <tbody>${orders.map(o => `<tr>
                                <td><a href="/Admin/Orders/Detail/${o.OrderId}" style="color:#2E7D32;font-weight:600;">#${o.OrderId}</a></td>
                                <td style="max-width:140px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${o.CustomerName || '---'}</td>
                                <td style="font-weight:600;">${(o.TotalAmount||0).toLocaleString('vi-VN')}đ</td>
                                <td><span class="badge-status ${statusMap[o.Status]||'badge-pending'}">${o.Status}</span></td>
                            </tr>`).join('')}</tbody>
                        </table>` : '<div style="padding:24px;text-align:center;color:#9ca3af;">Chưa có đơn hàng</div>';
                } catch(e) {}

                try {
                    const uRes = await apiFetch('/api/admin/users?PageSize=6');
                    const uData = await uRes.json();
                    const users = uData.Data || [];
                    document.getElementById('recentUsers').innerHTML = users.length ? `
                        <table class="mv-table">
                            <thead><tr><th>Họ tên</th><th>Email</th><th>Vai trò</th><th>Trạng thái</th></tr></thead>
                            <tbody>${users.map(u => `<tr>
                                <td style="font-weight:500;">${u.FullName || '---'}</td>
                                <td style="font-size:.8rem;color:#6b7280;">${u.Email}</td>
                                <td><span style="font-size:.75rem;">${u.Role||''}</span></td>
                                <td><span class="badge-status ${u.Status==='Active'?'badge-active':'badge-disable'}">${u.Status}</span></td>
                            </tr>`).join('')}</tbody>
                        </table>` : '<div style="padding:24px;text-align:center;color:#9ca3af;">Chưa có người dùng</div>';
                } catch(e) {}
            }
            load();
        })();
    </script>
}
