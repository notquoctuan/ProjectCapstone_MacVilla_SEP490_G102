@page
@model MacVilla_Web.Pages.Admin.Dashboard.IndexModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Bảng điều khiển - MacVilla</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        :root {
            --mv-green-dark: #7DA100;
            --mv-green-light: #f9fff0;
            --mv-green-border: #e2f0d1;
            --sidebar-width: 260px;
        }

        body {
            background-color: #f4f6f9;
            font-family: 'Segoe UI', Tahoma, sans-serif;
            margin: 0;
        }

        /* HEADER */
        .admin-header {
            background-color: var(--mv-green-dark);
            height: 65px;
            position: fixed;
            width: 100%;
            top: 0;
            z-index: 1050;
            padding: 0 20px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        .logo-custom {
            height: 35px;
            width: auto;
        }

        /* SIDEBAR */
        .admin-sidebar {
            width: var(--sidebar-width);
            background-color: #ffffff;
            height: 100vh;
            position: fixed;
            top: 65px;
            left: 0;
            border-right: 1px solid var(--mv-green-border);
            z-index: 1000;
            padding-top: 10px;
        }

        .nav-link-custom {
            padding: 12px 25px;
            display: flex;
            align-items: center;
            color: #444;
            text-decoration: none;
            font-weight: 500;
            transition: 0.2s;
            border-left: 4px solid transparent;
        }

        .nav-link-custom i {
            margin-right: 15px;
            font-size: 1.2rem;
            color: var(--mv-green-dark);
        }

        .nav-link-custom:hover {
            background-color: var(--mv-green-light);
            color: var(--mv-green-dark);
        }

        .nav-link-custom.active {
            background-color: var(--mv-green-dark);
            color: #ffffff !important;
            border-left: 4px solid #5d7800;
        }

        .nav-link-custom.active i {
            color: #ffffff;
        }

        /* MAIN CONTENT */
        .admin-wrapper {
            margin-left: var(--sidebar-width);
            margin-top: 65px;
            padding: 30px;
            min-height: calc(100vh - 115px);
        }

        /* DASHBOARD CARDS */
        .stat-card {
            border: none;
            border-radius: 12px;
            transition: transform 0.3s;
        }

        .stat-card:hover {
            transform: translateY(-5px);
        }

        .bg-mv-green { background-color: var(--mv-green-dark); color: white; }

        /* FOOTER */
        .admin-footer {
            margin-left: var(--sidebar-width);
            background-color: var(--mv-green-dark);
            color: #ffffff;
            padding: 15px 30px;
            font-size: 13px;
        }
    </style>
</head>
<body>
    <header class="admin-header d-flex align-items-center justify-content-between text-white">
        <div class="d-flex align-items-center">
            <img src="~/Image/Logo/logo-macvilla.png" alt="MacVilla" class="logo-custom me-3">
            <span class="fw-bold border-start ps-3 small text-uppercase">Hệ thống quản trị</span>
        </div>
        <div class="dropdown">
            <button class="btn btn-link text-white text-decoration-none dropdown-toggle" data-bs-toggle="dropdown">
                <i class="bi bi-person-circle me-1"></i> Admin MacVilla
            </button>
            <ul class="dropdown-menu dropdown-menu-end border-0 shadow">
                <li><a class="dropdown-item py-2" href="/Admin/Dashboard"><i class="bi bi-speedometer2 me-2"></i> Dashboard</a></li>
                <li><hr class="dropdown-divider"></li>
                <li>
                    <a class="dropdown-item small text-danger" asp-page="/Auth/Logout">
                        <i class="bi bi-box-arrow-right me-2"></i> Đăng xuất
                    </a>
                </li>
            </ul>
        </div>
    </header>

    <aside class="admin-sidebar shadow-sm">
        <div class="px-3 py-2 small text-muted text-uppercase fw-bold" style="font-size: 0.7rem;">Menu chính</div>
        <nav>
            <a asp-page="/Admin/Dashboard" class="nav-link-custom active">
                <i class="bi bi-speedometer2"></i> Tổng quan
            </a>
            <a asp-page="/Admin/Products/Index" class="nav-link-custom">
                <i class="bi bi-box-seam"></i> Sản phẩm
            </a>
            <a href="#" class="nav-link-custom">
                <i class="bi bi-receipt"></i> Đơn hàng
            </a>
            <a href="#" class="nav-link-custom">
                <i class="bi bi-people"></i> Khách hàng
            </a>
        </nav>
    </aside>

    <main class="admin-wrapper">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h4 class="fw-bold mb-0">Bảng điều khiển tổng quan</h4>
            <span class="badge bg-white text-dark shadow-sm p-2">Hôm nay: @DateTime.Now.ToString("dd/MM/yyyy")</span>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-md-3">
                <div class="card stat-card bg-mv-green shadow-sm">
                    <div class="card-body p-4 text-center">
                        <i class="bi bi-box-seam fs-1 mb-2"></i>
                        <h6 class="text-uppercase small fw-bold">Tổng sản phẩm</h6>
                        <h2 class="mb-0">0</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card stat-card bg-white shadow-sm border-start border-4 border-warning">
                    <div class="card-body p-4 text-center">
                        <i class="bi bi-cart-check fs-1 text-warning mb-2"></i>
                        <h6 class="text-uppercase small fw-bold text-muted">Đơn hàng mới</h6>
                        <h2 class="mb-0">0</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card stat-card bg-white shadow-sm border-start border-4 border-info">
                    <div class="card-body p-4 text-center">
                        <i class="bi bi-people fs-1 text-info mb-2"></i>
                        <h6 class="text-uppercase small fw-bold text-muted">Khách hàng</h6>
                        <h2 class="mb-0">0</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card stat-card bg-white shadow-sm border-start border-4 border-success">
                    <div class="card-body p-4 text-center">
                        <i class="bi bi-currency-dollar fs-1 text-success mb-2"></i>
                        <h6 class="text-uppercase small fw-bold text-muted">Doanh thu tháng</h6>
                        <h2 class="mb-0">0</h2>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-md-8">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-header bg-white py-3 fw-bold border-bottom">
                        <i class="bi bi-graph-up-arrow me-2 text-success"></i> TĂNG TRƯỞNG DOANH THU
                    </div>
                    <div class="card-body" style="height: 300px; display: flex; align-items: center; justify-content: center;">
                        <p class="text-muted italic">[Biểu đồ sẽ hiển thị tại đây]</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-header bg-white py-3 fw-bold border-bottom">
                        <i class="bi bi-lightning-charge me-2 text-warning"></i> HOẠT ĐỘNG GẦN ĐÂY
                    </div>
                    <div class="card-body">
                        <ul class="list-group list-group-flush small">
                            <li class="list-group-item border-0 px-0">
                                <i class="bi bi-circle-fill text-success me-2" style="font-size: 0.5rem;"></i>
                                
                            </li>
                            <li class="list-group-item border-0 px-0">
                                <i class="bi bi-circle-fill text-primary me-2" style="font-size: 0.5rem;"></i>
                                
                            </li>
                            <li class="list-group-item border-0 px-0">
                                <i class="bi bi-circle-fill text-warning me-2" style="font-size: 0.5rem;"></i>
                                
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <footer class="admin-footer d-flex justify-content-between">
        <div>&copy; 2026 <strong>MACVILLA</strong>. CMS System.</div>
        <div>Thiết kế bởi: <strong>HPSOFT</strong></div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
