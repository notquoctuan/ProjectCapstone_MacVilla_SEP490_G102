@page
@model MacVilla_Web.Pages.Admin.Products.CreateModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Thêm sản phẩm - MacVilla</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        :root {
            --mv-red-dark: #d30000;
            --mv-red-light: #fff5f5;
            --mv-red-border: #ffcccc;
            --mv-green-footer: #7DA100;
            --sidebar-width: 250px;
        }

        body {
            background-color: #f4f6f9;
            font-family: 'Segoe UI', Tahoma, sans-serif;
        }

        .admin-header {
            background-color: var(--mv-red-dark);
            height: 65px;
            position: fixed;
            width: 100%;
            top: 0;
            z-index: 1050;
            padding: 0 20px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        .logo-custom {
            max-height: 45px;
            width: auto;
        }

        .admin-sidebar {
            width: var(--sidebar-width);
            background-color: var(--mv-red-light);
            height: 100vh;
            position: fixed;
            top: 65px;
            left: 0;
            border-right: 1px solid var(--mv-red-border);
            padding-top: 15px;
            z-index: 1000;
        }

        .nav-admin-link {
            color: #333333;
            text-decoration: none;
            padding: 12px 20px;
            display: flex;
            align-items: center;
            font-weight: 500;
            transition: 0.2s;
            border-bottom: 1px solid rgba(211, 0, 0, 0.05);
        }

            .nav-admin-link i {
                margin-right: 12px;
                font-size: 18px;
                color: var(--mv-red-dark);
            }

            .nav-admin-link:hover {
                background-color: var(--mv-red-border);
                color: #000;
            }

        .admin-wrapper {
            margin-left: var(--sidebar-width);
            margin-top: 65px;
            padding: 30px;
            min-height: calc(100vh - 115px);
        }

        .admin-footer {
            margin-left: var(--sidebar-width);
            background-color: var(--mv-green-footer);
            color: #ffffff;
            padding: 12px 30px;
            font-size: 13px;
        }

        .card-header-mv {
            background-color: var(--mv-red-dark);
            color: white;
            font-weight: bold;
        }
    </style>
</head>
<body>
    <header class="admin-header d-flex align-items-center justify-content-between">
        <div class="d-flex align-items-center">
            <img src="/Logo/logo-macvilla.png" alt="MacVilla" class="logo-custom me-3">
            <span class="text-white fw-bold border-start ps-3 small text-uppercase">Hệ thống quản trị</span>
        </div>
    </header>

    <aside class="admin-sidebar">
        <nav>
            <a href="#" class="nav-admin-link"><i class="bi bi-house-door"></i> Tổng quan</a>
            <a asp-page="./Index" class="nav-admin-link active"><i class="bi bi-box-seam"></i> Sản phẩm</a>
            <a href="#" class="nav-admin-link"><i class="bi bi-receipt"></i> Đơn hàng</a>
        </nav>
    </aside>

    <main class="admin-wrapper">
        <div class="card border-0 shadow-sm">
            <div class="card-header card-header-mv py-3">
                <i class="bi bi-plus-circle me-2"></i>THÊM SẢN PHẨM MỚI
            </div>
            <div class="card-body p-4">
                <form method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold small">DANH MỤC</label>
                            <select asp-for="Product.CategoryId" class="form-select" asp-items="@(new SelectList(Model.Categories, "CategoryId", "Name"))">
                                <option value="">-- Chọn danh mục --</option>
                            </select>
                            <span asp-validation-for="Product.CategoryId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold small">TÊN SẢN PHẨM</label>
                            <input asp-for="Product.Name" class="form-control" placeholder="Nhập tên sản phẩm..." />
                            <span asp-validation-for="Product.Name" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold small">GIÁ BÁN (VNĐ)</label>
                            <input asp-for="Product.Price" type="number" class="form-control fw-bold text-danger" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold small">TRẠNG THÁI</label>
                            <select asp-for="Product.Status" class="form-select">
                                <option value="Enable">Đang kinh doanh</option>
                                <option value="Disable">Ngừng kinh doanh</option>
                                <option value="Pending">Chờ duyệt</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold small">HÌNH ẢNH</label>
                            <input asp-for="Product.ImageFiles" type="file" multiple class="form-control" accept="image/*" />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-bold small">MÔ TẢ CHI TIẾT</label>
                            <textarea asp-for="Product.Description" class="form-control" rows="4"></textarea>
                        </div>
                    </div>

                    <div class="mt-4 pt-3 border-top">
                        <button type="submit" class="btn btn-danger px-4 shadow-sm fw-bold">LƯU SẢN PHẨM</button>
                        <a asp-page="./Index" class="btn btn-outline-secondary px-4 ms-2">QUAY LẠI</a>
                    </div>
                </form>
            </div>
        </div>
    </main>

    <footer class="admin-footer d-flex justify-content-between">
        <div>&copy; 2026 <strong>MACVILLA</strong>. CMS System.</div>
        <div>Thiết kế bởi: HPSOFT</div>
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>