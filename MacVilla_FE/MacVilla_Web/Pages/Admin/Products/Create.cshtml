@page
@model MacVilla_Web.Pages.Admin.Products.CreateModel
@{
    ViewData["Title"] = "Thêm sản phẩm mới";
}

<div class="container-fluid mt-4">
    <div class="card shadow border-0 overflow-hidden">
        <div class="card-header bg-primary py-3">
            <h5 class="text-white mb-0"><i class="bi bi-plus-circle me-2"></i>THÊM SẢN PHẨM MỚI</h5>
        </div>

        <div class="card-body p-4">
            <form method="post" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Danh mục sản phẩm</label>
                        <select asp-for="Product.CategoryId" class="form-select"
                                asp-items="@(new SelectList(Model.Categories, "CategoryId", "Name"))">
                            <option value="">-- Chọn tên danh mục --</option>
                        </select>
                        <span asp-validation-for="Product.CategoryId" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Tên sản phẩm</label>
                        <input asp-for="Product.Name" class="form-control" placeholder="Ví dụ: iPhone 15 Pro Max" />
                        <span asp-validation-for="Product.Name" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label class="form-label fw-bold">Giá bán</label>
                        <div class="input-group">
                            <input asp-for="Product.Price" type="number" class="form-control text-danger fw-bold" placeholder="0" />
                            <span class="input-group-text bg-light">VNĐ</span>
                        </div>
                        <span asp-validation-for="Product.Price" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label class="form-label fw-bold">Trạng thái kinh doanh</label>
                        <select asp-for="Product.Status" class="form-select">
                            <option value="Enable" class="text-success">Đang kinh doanh (Enable)</option>
                            <option value="Disable" class="text-danger">Ngừng kinh doanh (Disable)</option>
                            <option value="Pending" class="text-warning">Chờ duyệt (Pending)</option>
                        </select>
                        <span asp-validation-for="Product.Status" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label class="form-label fw-bold">Hình ảnh sản phẩm</label>
                        <input asp-for="Product.ImageFiles" type="file" multiple class="form-control" accept="image/*" />
                        <div class="form-text text-muted small">Bạn có thể chọn một hoặc nhiều ảnh.</div>
                        <span asp-validation-for="Product.ImageFiles" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Mô tả sản phẩm</label>
                    <textarea asp-for="Product.Description" class="form-control" rows="5" placeholder="Nhập mô tả chi tiết về tính năng, cấu hình sản phẩm..."></textarea>
                    <span asp-validation-for="Product.Description" class="text-danger small"></span>
                </div>

                <div class="d-flex justify-content-end gap-2 border-top pt-3">
                    <a asp-page="./Index" class="btn btn-outline-secondary px-4">
                        <i class="bi bi-arrow-left"></i> Quay lại
                    </a>
                    <button type="submit" class="btn btn-primary px-5 shadow-sm">
                        <i class="bi bi-save me-1"></i> Lưu sản phẩm
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}