@page "/Admin/Products/Create"
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Thêm sản phẩm";
}

<div class="mv-page-header d-flex justify-content-between align-items-start">
    <div>
        <h1>Thêm sản phẩm mới</h1>
        <p>Điền thông tin và upload ảnh sản phẩm</p>
    </div>

    <a href="/Admin/Products" class="btn-outline-mv"
       style="text-decoration:none;display:flex;align-items:center;gap:6px;">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
</div>

<div style="display:grid;grid-template-columns:1fr 380px;gap:20px;">

    <!-- LEFT -->
    <div style="display:flex;flex-direction:column;gap:16px;">

        <!-- BASIC INFO -->
        <div class="mv-card">

            <div class="mv-card-header">
                <h5>Thông tin cơ bản</h5>
            </div>

            <div class="mv-card-body" style="display:flex;flex-direction:column;gap:16px;">

                <div>
                    <label class="form-label-mv">
                        Tên sản phẩm <span style="color:red;">*</span>
                    </label>

                    <input id="f-name"
                           type="text"
                           class="form-control-mv"
                           placeholder="Nhập tên sản phẩm...">
                </div>

                <div>
                    <label class="form-label-mv">Mô tả</label>

                    <textarea id="f-desc"
                              rows="4"
                              class="form-control-mv"
                              placeholder="Mô tả chi tiết sản phẩm..."></textarea>
                </div>

                <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">

                    <div>
                        <label class="form-label-mv">
                            Giá (VNĐ) <span style="color:red;">*</span>
                        </label>

                        <input id="f-price"
                               type="number"
                               class="form-control-mv"
                               placeholder="0"
                               min="1000">
                    </div>

                    <div>
                        <label class="form-label-mv">
                            Danh mục <span style="color:red;">*</span>
                        </label>

                        <select id="f-cat" class="form-select-mv">
                            <option value="">-- Chọn danh mục --</option>
                        </select>
                    </div>

                </div>
            </div>
        </div>

        <!-- IMAGE UPLOAD -->
        <div class="mv-card">

            <div class="mv-card-header">
                <h5>Hình ảnh sản phẩm</h5>
            </div>

            <div class="mv-card-body">

                <div id="dropZone"
                     onclick="document.getElementById('imgInput').click()"
                     style="border:2px dashed #d1d5db;border-radius:10px;padding:32px;text-align:center;cursor:pointer;background:#fafafa;">

                    <i class="bi bi-cloud-upload"
                       style="font-size:2rem;color:#9ca3af;"></i>

                    <p style="margin-top:8px;color:#6b7280;font-size:.875rem;">
                        Kéo thả ảnh vào đây hoặc
                        <strong style="color:#2E7D32;">nhấn để chọn</strong>
                    </p>

                    <p style="font-size:.75rem;color:#9ca3af;">
                        JPG, PNG, WEBP — tối đa 5MB — tối đa 10 ảnh
                    </p>

                </div>

                <input type="file"
                       id="imgInput"
                       multiple
                       accept=".jpg,.jpeg,.png,.webp"
                       style="display:none"
                       onchange="previewImages(this)">

                <div id="imgPreview"
                     style="margin-top:12px;display:grid;grid-template-columns:repeat(auto-fill,90px);gap:8px;">
                </div>

            </div>
        </div>

    </div>


    <!-- RIGHT -->
    <div style="display:flex;flex-direction:column;gap:16px;">

        <div class="mv-card">

            <div class="mv-card-header">
                <h5>Trạng thái</h5>
            </div>

            <div class="mv-card-body">

                <select id="f-status" class="form-select-mv">
                    <option value="Pending">Pending</option>
                    <option value="Enable">Enable</option>
                    <option value="Disable">Disable</option>
                </select>

                <div style="margin-top:12px;font-size:.8rem;color:#6b7280;">
                    Enable = hiển thị trên website
                </div>

            </div>
        </div>

        <div class="mv-card">

            <div class="mv-card-header">
                <h5>Thao tác</h5>
            </div>

            <div class="mv-card-body" style="display:flex;flex-direction:column;gap:8px;">

                <button onclick="doCreate()"
                        id="btnSave"
                        class="btn-primary-mv w-100">

                    <i class="bi bi-check-lg me-1"></i>
                    Lưu sản phẩm

                </button>

                <a href="/Admin/Products"
                   class="btn-outline-mv w-100 text-center"
                   style="text-decoration:none;">
                    Huỷ
                </a>

            </div>

        </div>

    </div>

</div>


@section Scripts {

    <script>

        let selectedFiles = [];

        const allowedTypes = [
            "image/jpeg",
            "image/png",
            "image/webp"
        ];

        const maxFileSize = 5 * 1024 * 1024;



        async function loadCategories() {
            const sel = document.getElementById("f-cat");
            sel.innerHTML = '<option value="">-- Chọn danh mục --</option>';

            try {
                const res = await apiFetch("/api/admin/category/getall");
                if (!res.ok) throw new Error("Không tải được danh mục");
                const cats = await res.json();

                cats.forEach(c => {
                    sel.innerHTML += `<option value="${c.CategoryId}">
                                        ${c.Name}
                                      </option>`;
                });
            } catch (e) {
                console.error(e);
                showToast(e.message || "Không thể tải danh mục", "error");
            }
        }



        function previewImages(input){

            const files = Array.from(input.files);

            for(const f of files){

                if(!allowedTypes.includes(f.type)){
                    showToast("Chỉ chấp nhận JPG PNG WEBP","error");
                    return;
                }

                if(f.size > maxFileSize){
                    showToast("Ảnh vượt quá 5MB","error");
                    return;
                }

            }

            if(selectedFiles.length + files.length > 10){
                showToast("Tối đa 10 ảnh","error");
                return;
            }

            selectedFiles.push(...files);

            renderPreview();

            input.value = "";

        }



        function renderPreview(){

            const grid = document.getElementById("imgPreview");

            grid.innerHTML = selectedFiles.map((f,i)=>{

                const url = URL.createObjectURL(f);

                return `<div style="position:relative">

                    <img src="${url}"
                         style="width:90px;height:90px;object-fit:cover;border-radius:6px;">

                    ${i===0?'<span style="position:absolute;top:4px;left:4px;background:#2E7D32;color:#fff;font-size:10px;padding:2px 4px;border-radius:3px;">MAIN</span>':''}

                    <button onclick="removeImg(${i})"
                            style="position:absolute;top:-6px;right:-6px;background:red;color:#fff;border:none;border-radius:50%;width:18px;height:18px;font-size:12px;">
                        ×
                    </button>

                </div>`;

            }).join("");

        }



        function removeImg(i){

            selectedFiles.splice(i,1);

            renderPreview();

        }



        const dz = document.getElementById("dropZone");

        dz.addEventListener("dragover",e=>{
            e.preventDefault();
        });

        dz.addEventListener("drop",e=>{
            e.preventDefault();

            previewImages({
                files:e.dataTransfer.files
            });

        });



        async function doCreate(){

            const name = document.getElementById("f-name").value.trim();
            const price = document.getElementById("f-price").value;
            const catId = document.getElementById("f-cat").value;
            const status = document.getElementById("f-status").value;
            const desc = document.getElementById("f-desc").value.trim();


            if(name.length < 2 || name.length > 200){
                showToast("Tên phải từ 2 đến 200 ký tự","error");
                return;
            }


            const priceNum = parseFloat(price);

            if(!price || priceNum < 1000 || priceNum > 999999999){
                showToast("Giá phải từ 1,000 đến 999,999,999","error");
                return;
            }


            if(!catId){
                showToast("Vui lòng chọn danh mục","error");
                return;
            }


            const form = new FormData();

            form.append("Name",name);
            form.append("Price",price);
            form.append("CategoryId",catId);
            form.append("Status",status);

            if(desc)
                form.append("Description",desc);

            selectedFiles.forEach(f=>{
                form.append("ImageFiles",f);
            });


            const btn = document.getElementById("btnSave");

            btn.disabled = true;
            btn.innerHTML = "Đang lưu...";


            try{

                const token = getToken();

                const r = await fetch("/api/admin/products",{
                    method:"POST",
                    headers:{
                        "Authorization":"Bearer "+token
                    },
                    body:form
                });

                const data = await r.json();

                if(!r.ok)
                    throw new Error(data.message || "Tạo thất bại");


                showToast("Tạo sản phẩm thành công","success");

                setTimeout(()=>{
                    window.location="/Admin/Products";
                },1200);


            }
            catch(e){

                showToast(e.message,"error");

                btn.disabled=false;

                btn.innerHTML="Lưu sản phẩm";

            }

        }



        loadCategories();

    </script>

}