@page "/Admin/Products/Create"
@{
    Layout = "_AdminLayout"; ViewData["Title"] = "Thêm sản phẩm";
}

<div class="mv-page-header d-flex justify-content-between align-items-start">
    <div><h1>Thêm sản phẩm mới</h1><p>Điền thông tin và upload ảnh sản phẩm</p></div>
    <a href="/Admin/Products" class="btn-outline-mv" style="text-decoration:none;display:flex;align-items:center;gap:6px;">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
</div>

<div style="display:grid;grid-template-columns:1fr 380px;gap:20px;">
    <!-- Left -->
    <div style="display:flex;flex-direction:column;gap:16px;">
        <div class="mv-card">
            <div class="mv-card-header"><h5>Thông tin cơ bản</h5></div>
            <div class="mv-card-body" style="display:flex;flex-direction:column;gap:16px;">
                <div>
                    <label class="form-label-mv">Tên sản phẩm <span style="color:red;">*</span></label>
                    <input type="text" id="f-name" class="form-control-mv" placeholder="Nhập tên sản phẩm...">
                </div>
                <div>
                    <label class="form-label-mv">Mô tả</label>
                    <textarea id="f-desc" class="form-control-mv" rows="4" placeholder="Mô tả chi tiết sản phẩm..."></textarea>
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
                    <div>
                        <label class="form-label-mv">Giá (VNĐ) <span style="color:red;">*</span></label>
                        <input type="number" id="f-price" class="form-control-mv" placeholder="0" min="0">
                    </div>
                    <div>
                        <label class="form-label-mv">Danh mục <span style="color:red;">*</span></label>
                        <select id="f-cat" class="form-select-mv"><option value="">-- Chọn danh mục --</option></select>
                    </div>
                </div>
            </div>
        </div>

        <div class="mv-card">
            <div class="mv-card-header"><h5>Hình ảnh sản phẩm</h5></div>
            <div class="mv-card-body">
                <div id="dropZone" onclick="document.getElementById('imgInput').click()" style="border:2px dashed #d1d5db;border-radius:10px;padding:32px;text-align:center;cursor:pointer;transition:.2s;background:#fafafa;">
                    <i class="bi bi-cloud-upload" style="font-size:2rem;color:#9ca3af;"></i>
                    <p style="margin-top:8px;color:#6b7280;font-size:.875rem;">Kéo thả ảnh vào đây hoặc <strong style="color:#2E7D32;">nhấn để chọn</strong></p>
                    <p style="font-size:.75rem;color:#9ca3af;">JPG, PNG, WEBP — tối đa 5MB, tối đa 10 ảnh</p>
                </div>
                <input type="file" id="imgInput" multiple accept=".jpg,.jpeg,.png,.webp" style="display:none;" onchange="previewImages(this)">
                <div class="img-preview-grid" id="imgPreview"></div>
            </div>
        </div>
    </div>

    <!-- Right -->
    <div style="display:flex;flex-direction:column;gap:16px;">
        <div class="mv-card">
            <div class="mv-card-header"><h5>Trạng thái</h5></div>
            <div class="mv-card-body">
                <select id="f-status" class="form-select-mv">
                    <option value="Pending">Pending</option>
                    <option value="Enable">Enable</option>
                    <option value="Disable">Disable</option>
                </select>
                <div style="margin-top:12px;padding:10px;background:#f9fafb;border-radius:8px;font-size:.78rem;color:#6b7280;">
                    <div><strong>Enable</strong>: Hiển thị trên web</div>
                    <div><strong>Disable</strong>: Ẩn khỏi web</div>
                    <div><strong>Pending</strong>: Chờ duyệt</div>
                </div>
            </div>
        </div>

        <div class="mv-card">
            <div class="mv-card-header"><h5>Thao tác</h5></div>
            <div class="mv-card-body" style="display:flex;flex-direction:column;gap:8px;">
                <button onclick="doCreate()" class="btn-primary-mv w-100" id="btnSave">
                    <i class="bi bi-check-lg me-1"></i> Lưu sản phẩm
                </button>
                <a href="/Admin/Products" class="btn-outline-mv w-100 text-center" style="text-decoration:none;">Huỷ</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let selectedFiles = [];

        async function loadCategories() {
            const r = await apiFetch('/api/admin/category/getall');
            const cats = await r.json();
            const sel = document.getElementById('f-cat');
            cats.forEach(c => sel.innerHTML += `<option value="${c.CategoryId}">${c.Name}</option>`);
        }

        function previewImages(input) {
            selectedFiles = [...selectedFiles, ...Array.from(input.files)];
            renderPreview();
            input.value = '';
        }

        function renderPreview() {
            const grid = document.getElementById('imgPreview');
            grid.innerHTML = selectedFiles.map((f, i) => {
                const url = URL.createObjectURL(f);
                return `<div class="img-preview-item">
                    <img src="${url}">
                    ${i===0 ? '<span class="img-main-badge">CHÍNH</span>' : ''}
                    <button class="btn-del-img" onclick="removeImg(${i})">×</button>
                </div>`;
            }).join('');
        }

        function removeImg(i) { selectedFiles.splice(i, 1); renderPreview(); }

        // Drag & drop
        const dz = document.getElementById('dropZone');
        dz.addEventListener('dragover', e => { e.preventDefault(); dz.style.borderColor='#4CAF50'; dz.style.background='#f0fff4'; });
        dz.addEventListener('dragleave', () => { dz.style.borderColor='#d1d5db'; dz.style.background='#fafafa'; });
        dz.addEventListener('drop', e => {
            e.preventDefault();
            dz.style.borderColor='#d1d5db'; dz.style.background='#fafafa';
            selectedFiles = [...selectedFiles, ...Array.from(e.dataTransfer.files)];
            renderPreview();
        });

        async function doCreate() {
            const name = document.getElementById('f-name').value.trim();
            const price = document.getElementById('f-price').value;
            const catId = document.getElementById('f-cat').value;
            const status = document.getElementById('f-status').value;
            const desc = document.getElementById('f-desc').value.trim();

            if (!name) { showToast('Vui lòng nhập tên sản phẩm', 'error'); return; }
            if (!price || parseFloat(price) < 0) { showToast('Vui lòng nhập giá hợp lệ', 'error'); return; }
            if (!catId) { showToast('Vui lòng chọn danh mục', 'error'); return; }

            const btn = document.getElementById('btnSave');
            btn.disabled = true; btn.innerHTML = '<i class="bi bi-hourglass"></i> Đang lưu...';

            const form = new FormData();
            form.append('Name', name);
            form.append('Price', price);
            form.append('CategoryId', catId);
            form.append('Status', status);
            if (desc) form.append('Description', desc);
            selectedFiles.forEach(f => form.append('ImageFiles', f));

            try {
                const token = getToken();
                const r = await fetch('https://localhost:7262/api/admin/products', {
                    method: 'POST',
                    headers: { 'Authorization': 'Bearer ' + token },
                    body: form
                });
                const data = await r.json();
                if (!r.ok) throw new Error(data.message || 'Tạo thất bại');
                showToast('Tạo sản phẩm thành công!', 'success');
                setTimeout(() => window.location.href = '/Admin/Products', 1200);
            } catch(e) {
                showToast(e.message, 'error');
                btn.disabled = false; btn.innerHTML = '<i class="bi bi-check-lg me-1"></i> Lưu sản phẩm';
            }
        }

        loadCategories();
    </script>
}
