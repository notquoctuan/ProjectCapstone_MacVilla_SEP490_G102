@page "{id:long}"
@model MacVilla_Web.Pages.Admin.Products.EditModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Chỉnh sửa sản phẩm - MacVilla</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        :root {
            --mv-green-dark: #7DA100;
            --mv-green-light: #f9fff0;
            --mv-green-border: #e2f0d1;
        }

        body {
            background-color: #f4f6f9;
            font-family: 'Segoe UI', Tahoma, sans-serif;
            margin: 0;
        }

        /* HEADER - Đồng bộ hoàn toàn với Index */
        .admin-header {
            background-color: var(--mv-green-dark);
            height: 65px;
            position: fixed;
            width: 100%;
            top: 0;
            z-index: 1050;
            padding: 0 30px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        .logo-custom {
            height: 35px;
            width: auto;
        }

        /* MAIN CONTENT - Căn giữa, không sidebar */
        .admin-wrapper {
            margin-top: 65px;
            padding: 40px 15%; /* Giới hạn độ rộng form để nhìn cân đối hơn */
            min-height: calc(100vh - 115px);
        }

        @@media (max-width: 992px) {
            .admin-wrapper {
                padding: 30px 5%;
            }
        }

        /* CARD STYLE */
        .card-custom {
            border: none;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.08);
        }

        .card-header-mv {
            background-color: var(--mv-green-dark);
            color: #ffffff;
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            padding: 1.2rem;
        }

        /* FORM ELEMENTS */
        .form-label {
            color: #555;
            margin-bottom: 0.5rem;
        }

        .form-control:focus, .form-select:focus {
            border-color: var(--mv-green-dark);
            box-shadow: 0 0 0 0.25rem rgba(125, 161, 0, 0.1);
        }

        .img-preview-container {
            border: 2px dashed var(--mv-green-border);
            border-radius: 10px;
            padding: 10px;
            background: #fff;
            display: inline-block;
        }

        /* FOOTER */
        .admin-footer {
            background-color: var(--mv-green-dark);
            color: #ffffff;
            padding: 15px 15%;
            font-size: 13px;
        }

        .btn-mv-save {
            background-color: var(--mv-green-dark);
            color: white;
            border: none;
            padding: 10px 30px;
            font-weight: 600;
            transition: 0.3s;
        }

            .btn-mv-save:hover {
                background-color: #6a8900;
                color: white;
                transform: translateY(-2px);
            }
    </style>
</head>
<body>
    <header class="admin-header d-flex align-items-center justify-content-between">
        <div class="d-flex align-items-center">
            <img src="~/Image/Logo/logo-macvilla.png" alt="MacVilla" class="logo-custom me-3">
            <span class="text-white fw-bold border-start ps-3 small text-uppercase d-none d-sm-inline">Hệ thống quản trị</span>
        </div>

        <div class="dropdown">
            <button class="btn btn-link text-white text-decoration-none dropdown-toggle small" type="button" data-bs-toggle="dropdown">
                <i class="bi bi-person-circle me-1"></i> Admin MacVilla
            </button>
            <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                <li><a class="dropdown-item small" href="/Admin/Dashboard"><i class="bi bi-speedometer2 me-2"></i> Dashboard</a></li>
                <li><a class="dropdown-item small" asp-page="./Index"><i class="bi bi-box-seam me-2"></i> Quản lý sản phẩm</a></li>
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item small text-danger" asp-page="/Auth/Logout"><i class="bi bi-box-arrow-right me-2"></i> Đăng xuất</a></li>
            </ul>
        </div>
    </header>

    <main class="admin-wrapper">
        <nav aria-label="breadcrumb" class="mb-4">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-page="./Index" class="text-decoration-none" style="color: var(--mv-green-dark)">Sản phẩm</a></li>
                <li class="breadcrumb-item active" aria-current="page">Chỉnh sửa chi tiết</li>
            </ol>
        </nav>

        <div class="card card-custom">
            <div class="card-header card-header-mv">
                <i class="bi bi-pencil-square me-2"></i> Chỉnh sửa sản phẩm: @Model.UpdateData.Name
            </div>
            <div class="card-body p-4 p-lg-5">
                <form method="post" enctype="multipart/form-data">
                    <input type="hidden" asp-for="UpdateData.ProductId" />
                    <input type="hidden" asp-for="UpdateData.ImageUrl" />

                    <div class="row g-4">
                        <div class="col-md-8">
                            <label class="form-label fw-bold small">TÊN SẢN PHẨM</label>
                            <input asp-for="UpdateData.Name" class="form-control form-control-lg" placeholder="Nhập tên sản phẩm..." />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold small">TRẠNG THÁI</label>
                            <select asp-for="UpdateData.Status" class="form-select form-select-lg">
                                <option value="Enable">Kích hoạt (Hiển thị)</option>
                                <option value="Disable">Tạm ẩn</option>
                                <option value="Pending">Đang chờ xử lý</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold small">GIÁ BÁN (VNĐ)</label>
                            <div class="input-group input-group-lg">
                                <input asp-for="UpdateData.Price" type="number" class="form-control fw-bold text-success" />
                                <span class="input-group-text">₫</span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold small">DANH MỤC</label>
                            <select asp-for="UpdateData.CategoryId" class="form-select form-select-lg" asp-items="@(new SelectList(Model.Categories, "CategoryId", "Name"))"></select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold small text-uppercase">Ảnh đang hiển thị</label>
                            <div class="mt-2">
                                <div class="img-preview-container">
                                    <img src="https://localhost:7262@(Model.UpdateData.ImageUrl)" class="rounded" style="height: 150px; width: 150px; object-fit: cover;" onerror="this.src='https://placehold.co/150x150?text=No+Image'">
                                </div>
                            </div>
                        </div>
                        <div class="col-md-8">
                            <label class="form-label fw-bold small text-uppercase">Tải lên ảnh mới</label>
                            <div class="p-4 border rounded bg-light">
                                <input type="file" name="NewImage" class="form-control" accept="image/*" />
                                <div class="form-text mt-2 italic"><i class="bi bi-info-circle me-1"></i> Để trống nếu bạn muốn giữ lại ảnh cũ.</div>
                            </div>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-bold small text-uppercase">Mô tả sản phẩm</label>
                            <textarea asp-for="UpdateData.Description" class="form-control" rows="6" placeholder="Nhập thông tin chi tiết sản phẩm..."></textarea>
                        </div>
                    </div>

                    <div class="mt-5 pt-4 border-top d-flex gap-2">
                        <button type="submit" class="btn btn-mv-save shadow-sm shadow">
                            <i class="bi bi-save me-2"></i> LƯU THAY ĐỔI
                        </button>
                        <a asp-page="./Index" class="btn btn-outline-secondary px-4 fw-bold d-flex align-items-center">
                            HỦY BỎ
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </main>

    <footer class="admin-footer d-flex justify-content-between">
        <div>&copy; 2026 <strong>MACVILLA</strong>. CMS System.</div>
