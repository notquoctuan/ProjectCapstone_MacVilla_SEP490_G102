@page "{id:long}"
@model MacVilla_Web.Pages.Admin.Products.EditModel
@{
    ViewData["Title"] = "Chỉnh sửa sản phẩm";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8 shadow-sm p-4 border rounded bg-white">
            <h3 class="text-warning mb-4">CHỈNH SỬA SẢN PHẨM</h3>

            <form method="post" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                @* Hidden fields *@
                <input type="hidden" asp-for="UpdateData.ProductId" />
                <input type="hidden" asp-for="UpdateData.ImageUrl" />

                <div class="mb-3">
                    <label class="form-label fw-bold">Tên sản phẩm</label>
                    <input asp-for="UpdateData.Name" class="form-control" placeholder="Nhập tên sản phẩm" />
                    <span asp-validation-for="UpdateData.Name" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Giá bán (VNĐ)</label>
                        <input asp-for="UpdateData.Price" type="number" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Danh mục sản phẩm</label>
                        <select asp-for="UpdateData.CategoryId" class="form-select"
                                asp-items="@(new SelectList(Model.Categories, "CategoryId", "Name"))">
                            <option value="">-- Chọn danh mục --</option>
                        </select>
                        <span asp-validation-for="UpdateData.CategoryId" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Trạng thái</label>
                    <select asp-for="UpdateData.Status" class="form-select">
                        <option value="Enable">Kích hoạt (Enable)</option>
                        <option value="Disable">Tạm ẩn (Disable)</option>
                        <option value="Pending">Đang chờ (Pending)</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold d-block">Hình ảnh hiện tại</label>
                    <div class="mb-2">
                        <img src="https://localhost:7262@(Model.UpdateData.ImageUrl)"
                             alt="Product" width="150" class="img-thumbnail" />
                    </div>
                    <label class="form-label small text-primary">Thay đổi ảnh (Chọn file nếu muốn thay thế):</label>
                    <input type="file" name="NewImage" class="form-control" accept="image/*" />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Mô tả sản phẩm</label>
                    <textarea asp-for="UpdateData.Description" class="form-control" rows="3"></textarea>
                </div>

                <div class="mt-4 d-flex gap-2">
                    <button type="submit" class="btn btn-warning px-4 fw-bold">CẬP NHẬT NGAY</button>
                    <a asp-page="./Index" class="btn btn-outline-secondary">Hủy bỏ</a>
                </div>
            </form>
        </div>
    </div>
</div>