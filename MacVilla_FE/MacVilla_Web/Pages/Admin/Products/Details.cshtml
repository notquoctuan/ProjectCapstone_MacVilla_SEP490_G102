@page "{id:long}"
@model MacVilla_Web.Pages.Admin.Products.DetailModel
@{
    ViewData["Title"] = "Chi tiết sản phẩm";
    var p = Model.Product!;
    var main = p.Images.FirstOrDefault(i => i.IsMain) ?? p.Images.FirstOrDefault();
}

<div class="det-page">
    <div class="det-head">
        <a asp-page="./Index" class="back-link">← Danh sách</a>
        <div style="display:flex;align-items:center;gap:.75rem">
            <span class="badge badge--@(p.Status.ToLower())">@p.Status</span>
            <a asp-page="./Edit" asp-route-id="@p.ProductId" class="btn-edit">✎ Chỉnh sửa</a>
        </div>
    </div>

    @if (Model.SuccessMessage != null)
    {
        <div class="toast toast--ok">✓ @Model.SuccessMessage</div>
    }
    @if (Model.ErrorMessage != null)
    {
        <div class="toast toast--err">⚠ @Model.ErrorMessage</div>
    }

    <div class="det-layout">
        <!-- Gallery -->
        <div class="det-gallery">
            <div class="gal-main">
                @if (main != null)
                {
                    <img src="@($"https://localhost:7262{main.ImageUrl}")" alt="@p.Name" id="mainImg" class="gal-main__img" />
                }
                else
                {
                    <div class="gal-empty">
                        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#cbd5e1" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2" /><circle cx="8.5" cy="8.5" r="1.5" /><polyline points="21 15 16 10 5 21" /></svg>
                        <span>Không có ảnh</span>
                    </div>
                }
            </div>
            @if (p.Images.Count > 1)
            {
                <div class="gal-strip">
                    @foreach (var img in p.Images)
                    {
                        <div class="gal-thumb @(img.IsMain ? "gal-thumb--on" : "")"
                             onclick="switchImg('@($"https://localhost:7262{img.ImageUrl}")', this)">
                            <img src="@($"https://localhost:7262{img.ImageUrl}")" alt="" />
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Info -->
        <div class="det-info">
            <p class="det-id">#@p.ProductId</p>
            <h1 class="det-name">@p.Name</h1>
            <div class="det-price">@p.Price.ToString("N0") <span class="det-curr">₫</span></div>

            <div class="info-grid">
                <div class="info-cell">
                    <div class="info-k">Danh mục</div>
                    <div class="info-v">@(p.CategoryName ?? "—")</div>
                </div>
                <div class="info-cell">
                    <div class="info-k">Trạng thái</div>
                    <div class="info-v"><span class="badge badge--@(p.Status.ToLower())">@p.Status</span></div>
                </div>
                <div class="info-cell">
                    <div class="info-k">Ngày tạo</div>
                    <div class="info-v">@p.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                </div>
                <div class="info-cell">
                    <div class="info-k">Số ảnh</div>
                    <div class="info-v">@p.Images.Count ảnh</div>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(p.Description))
            {
                <div class="det-desc">
                    <div class="det-desc__title">Mô tả sản phẩm</div>
                    <p>@p.Description</p>
                </div>
            }

            <div class="qs-bar">
                <span class="qs-label">Đổi trạng thái:</span>
                @foreach (var s in new[] { "Enable", "Disable", "Pending" })
                {
                    if (s != p.Status)
                    {
                        <form method="post" asp-page-handler="ChangeStatus" style="display:inline">
                            <input type="hidden" name="status" value="@s" />
                            <button type="submit" class="qs-btn qs-btn--@s.ToLower()">@s</button>
                        </form>
                    }
                }
            </div>
        </div>
    </div>
</div>

<style>
    .det-page {
        padding: 2rem;
        font-family: 'DM Sans','Segoe UI',sans-serif;
        max-width: 1100px
    }

    .det-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.5rem
    }

    .back-link {
        color: #6366f1;
        font-size: .875rem;
        font-weight: 500;
        text-decoration: none
    }

    .btn-edit {
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        background: #0f172a;
        color: #fff;
        padding: .5rem 1rem;
        border-radius: 7px;
        font-size: .85rem;
        font-weight: 600;
        text-decoration: none;
        transition: background .15s
    }

        .btn-edit:hover {
            background: #1e293b
        }

    .toast {
        padding: .75rem 1rem;
        border-radius: 9px;
        margin-bottom: 1rem;
        font-size: .85rem;
        font-weight: 500
    }

    .toast--ok {
        background: #ecfdf5;
        color: #065f46;
        border: 1px solid #a7f3d0
    }

    .toast--err {
        background: #fef2f2;
        color: #991b1b;
        border: 1px solid #fecaca
    }

    .det-layout {
        display: grid;
        grid-template-columns: 400px 1fr;
        gap: 2rem;
        align-items: start
    }

    .gal-main {
        border: 1.5px solid #e2e8f0;
        border-radius: 12px;
        overflow: hidden;
        aspect-ratio: 1;
        background: #f8fafc;
        display: flex;
        align-items: center;
        justify-content: center
    }

    .gal-main__img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block
    }

    .gal-empty {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: .5rem;
        color: #94a3b8;
        font-size: .85rem
    }

    .gal-strip {
        display: flex;
        gap: .5rem;
        flex-wrap: wrap;
        margin-top: .65rem
    }

    .gal-thumb {
        width: 62px;
        height: 62px;
        border-radius: 7px;
        overflow: hidden;
        border: 2px solid #e2e8f0;
        cursor: pointer;
        transition: border-color .15s;
        flex-shrink: 0
    }

        .gal-thumb:hover, .gal-thumb--on {
            border-color: #6366f1
        }

        .gal-thumb img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block
        }

    .det-id {
        font-size: .72rem;
        color: #94a3b8;
        font-weight: 500;
        margin: 0 0 .3rem
    }

    .det-name {
        font-size: 1.6rem;
        font-weight: 700;
        color: #0f172a;
        margin: 0 0 .5rem;
        line-height: 1.25
    }

    .det-price {
        font-size: 1.9rem;
        font-weight: 800;
        color: #6366f1;
        margin-bottom: 1.25rem
    }

    .det-curr {
        font-size: .9rem;
        font-weight: 400;
        color: #94a3b8
    }

    .info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .75rem;
        margin-bottom: 1.25rem
    }

    .info-cell {
        background: #f8fafc;
        border: 1.5px solid #f1f5f9;
        border-radius: 9px;
        padding: .8rem .9rem
    }

    .info-k {
        font-size: .68rem;
        font-weight: 700;
        color: #94a3b8;
        text-transform: uppercase;
        letter-spacing: .06em;
        margin-bottom: .2rem
    }

    .info-v {
        font-size: .875rem;
        font-weight: 600;
        color: #0f172a
    }

    .det-desc {
        background: #fafbff;
        border: 1.5px solid #e2e8f0;
        border-radius: 9px;
        padding: 1.1rem;
        margin-bottom: 1.25rem
    }

    .det-desc__title {
        font-size: .7rem;
        font-weight: 700;
        color: #94a3b8;
        text-transform: uppercase;
        letter-spacing: .06em;
        margin-bottom: .5rem
    }

    .det-desc p {
        color: #374151;
        font-size: .875rem;
        line-height: 1.65;
        margin: 0;
        white-space: pre-wrap
    }

    .badge {
        padding: .22rem .6rem;
        border-radius: 999px;
        font-size: .7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .04em
    }

    .badge--enable {
        background: #dcfce7;
        color: #166534
    }

    .badge--disable {
        background: #fee2e2;
        color: #991b1b
    }

    .badge--pending {
        background: #fef9c3;
        color: #854d0e
    }

    .qs-bar {
        display: flex;
        align-items: center;
        gap: .6rem;
        flex-wrap: wrap
    }

    .qs-label {
        font-size: .75rem;
        font-weight: 600;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: .04em
    }

    .qs-btn {
        padding: .35rem .8rem;
        border-radius: 6px;
        border: 1.5px solid;
        font-size: .78rem;
        font-weight: 600;
        cursor: pointer;
        background: #fff;
        transition: all .15s
    }

    .qs-btn--enable {
        border-color: #22c55e;
        color: #166534
    }

        .qs-btn--enable:hover {
            background: #dcfce7
        }

    .qs-btn--disable {
        border-color: #ef4444;
        color: #991b1b
    }

        .qs-btn--disable:hover {
            background: #fee2e2
        }

    .qs-btn--pending {
        border-color: #f59e0b;
        color: #854d0e
    }

        .qs-btn--pending:hover {
            background: #fef9c3
        }

    @@media(max-width:900px) {
        .det-layout {
            grid-template-columns: 1fr
        }
    }
</style>
<script>
    function switchImg(url, el) {
        document.getElementById('mainImg').src = url;
        document.querySelectorAll('.gal-thumb').forEach(t => t.classList.remove('gal-thumb--on'));
        el.classList.add('gal-thumb--on');
    }
</script>
