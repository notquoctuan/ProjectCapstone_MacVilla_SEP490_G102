@page "/Admin/Products"
@model MacVilla_Web.Pages.Admin.Products.IndexModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản lý Sản phẩm";
}

<div class="prd-page">

    <!-- HEADER -->
    <div class="prd-header">
        <div class="prd-header__left">
            <h1 class="prd-title">Sản phẩm</h1>
            <span class="prd-count">@Model.Products?.TotalCount</span>
        </div>

        <a asp-page="./Create" class="btn-prd-primary">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <line x1="12" y1="5" x2="12" y2="19" />
                <line x1="5" y1="12" x2="19" y2="12" />
            </svg>
            Thêm sản phẩm
        </a>
    </div>

    <!-- TOAST -->
    @if (Model.SuccessMessage != null)
    {
        <div class="toast toast--ok" id="prd-toast">✓ @Model.SuccessMessage</div>
    }

    @if (Model.ErrorMessage != null)
    {
        <div class="toast toast--err" id="prd-toast">⚠ @Model.ErrorMessage</div>
    }

    <!-- FILTER -->
    <form method="get" class="prd-filters">

        <input type="text"
               name="SearchName"
               value="@Model.SearchName"
               placeholder="Tìm tên sản phẩm…"
               class="f-input" />

        <input type="text"
               name="SearchCategory"
               value="@Model.SearchCategory"
               placeholder="Danh mục…"
               class="f-input" />

        <select name="SearchStatus" class="f-select">

            <option value="">Tất cả trạng thái</option>

            <option value="Enable" selected="@(Model.SearchStatus == "Enable")">
                Enable
            </option>

            <option value="Disable" selected="@(Model.SearchStatus == "Disable")">
                Disable
            </option>

            <option value="Pending" selected="@(Model.SearchStatus == "Pending")">
                Pending
            </option>

        </select>


        <select name="SortOrder" class="f-select">

            <option value="newest" selected="@(Model.SortOrder == "newest")">
                Mới nhất
            </option>

            <option value="oldest" selected="@(Model.SortOrder == "oldest")">
                Cũ nhất
            </option>

            <option value="price_asc" selected="@(Model.SortOrder == "price_asc")">
                Giá tăng
            </option>

            <option value="price_desc" selected="@(Model.SortOrder == "price_desc")">
                Giá giảm
            </option>

        </select>

        <button type="submit" class="btn-filter">
            Lọc
        </button>

        @if (!string.IsNullOrEmpty(Model.SearchName)
                || !string.IsNullOrEmpty(Model.SearchCategory)
                || !string.IsNullOrEmpty(Model.SearchStatus))
        {
            <a asp-page="./Index" class="btn-clear">Xóa bộ lọc</a>
        }

    </form>

    <!-- TABLE -->
    @if (Model.Products == null || !Model.Products.Data.Any())
    {
        <div class="prd-empty">
            <p>Không tìm thấy sản phẩm.</p>
        </div>
    }
    else
    {

        <div class="prd-table-wrap">

            <table class="prd-table">

                <thead>
                    <tr>
                        <th></th>
                        <th>Sản phẩm</th>
                        <th>Danh mục</th>
                        <th>Giá</th>
                        <th>Trạng thái</th>
                        <th>Ngày tạo</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var p in Model.Products.Data)
                    {
                        var statusLower = p.Status?.ToLower() ?? "pending";

                        <tr>

                            <td>

                                @if (!string.IsNullOrEmpty(p.ImageUrl))
                                {
                                    <img src="@($"https://localhost:7262{p.ImageUrl}")"
                                         class="prd-thumb"
                                         alt="@p.Name" />
                                }
                                else
                                {
                                    <div class="prd-thumb prd-thumb--empty"></div>
                                }

                            </td>

                            <td>

                                <a asp-page="./Details"
                                   asp-route-id="@p.ProductId"
                                   class="prd-name">
                                    @p.Name
                                </a>

                                <div class="prd-subid">#@p.ProductId</div>

                            </td>

                            <td class="td-muted">
                                @(p.CategoryName ?? "—")
                            </td>

                            <td class="td-price">

                                @if (p.Price.HasValue)
                                {
                                    @p.Price.Value.ToString("N0")
                                    <span class="td-currency"> ₫</span>
                                }

                            </td>

                            <td>
                                <span class="badge badge--@statusLower">
                                    @p.Status
                                </span>
                            </td>

                            <td class="td-muted">
                                @(p.CreatedAt?.ToString("dd/MM/yyyy") ?? "—")
                            </td>

                            <td>

                                <a asp-page="./Edit"
                                   asp-route-id="@p.ProductId"
                                   class="act-btn">
                                    Edit
                                </a>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>


        <!-- PAGINATION -->
        @if (Model.Products.TotalPages > 1)
        {

            <div class="prd-pagination">

                <span class="pg-info">

                    Trang
                    @Model.Products.PageNumber
                    /
                    @Model.Products.TotalPages

                    ·

                    @Model.Products.TotalCount sản phẩm

                </span>

                <div class="pg-btns">

                    @if (Model.Products.PageNumber > 1)
                    {
                        <a asp-page="./Index"
                           asp-route-pageNumber="@(Model.Products.PageNumber - 1)"
                           class="pg-btn">
                            ←
                        </a>
                    }

                    @for (int i = 1; i <= Model.Products.TotalPages; i++)
                    {

                        <a asp-page="./Index"
                           asp-route-pageNumber="@i"
                           class="pg-btn @(i == Model.Products.PageNumber ? "pg-btn--on" : "")">
                            @i
                        </a>

                    }

                    @if (Model.Products.PageNumber < Model.Products.TotalPages)
                    {
                        <a asp-page="./Index"
                           asp-route-pageNumber="@(Model.Products.PageNumber + 1)"
                           class="pg-btn">
                            →
                        </a>
                    }

                </div>

            </div>

        }

    }

</div>