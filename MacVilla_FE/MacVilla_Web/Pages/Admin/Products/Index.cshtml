@page
@model MacVilla_Web.Pages.Admin.Products.IndexModel

<div class="container mt-4">
    <h2 class="text-primary mb-4 text-uppercase">Quản lý sản phẩm</h2>

    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-4">
                    <label class="form-label fw-bold">Tìm theo tên</label>
                    <input type="text" asp-for="Name" class="form-control" placeholder="Nhập tên sản phẩm...">
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold">Danh mục</label>
                    <input type="text" asp-for="CategoryName" class="form-control" placeholder="Tên danh mục...">
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold">Sắp xếp giá</label>
                    <select asp-for="SortOrder" class="form-select">
                        <option value="">Mới nhất</option>
                        <option value="price_asc">Giá tăng dần</option>
                        <option value="price_desc">Giá giảm dần</option>
                    </select>
                </div>
                <div class="col-md-2 d-flex align-items-end gap-2">
                    <button type="submit" class="btn btn-primary w-100">Lọc</button>
                    <a asp-page="./Index" class="btn btn-outline-secondary">Xóa</a>
                </div>
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h2 class="text-primary">DANH SÁCH SẢN PHẨM</h2>
                    <a class="btn btn-success btn-sm" asp-page="/Admin/Products/Create">
                        <i class="bi bi-plus-lg"></i> + Thêm sản phẩm mới
                    </a>
                </div>
            </form>
        </div>
    </div>

    <table class="table table-hover border shadow-sm bg-white">
        <thead class="table-dark">
            <tr>
                <th>Ảnh</th>
                <th>Tên sản phẩm</th>
                <th>Danh mục</th>
                <th>Giá</th>
                <th>Trạng thái</th>
                <th class="text-center">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.PagedProducts.Data)
            {
                <tr>
                    <td><img src="https://localhost:7262@(item.ImageUrl)" width="60" class="img-thumbnail" /></td>
                    <td class="align-middle fw-bold">@item.Name</td>
                    <td class="align-middle">@item.CategoryName</td>
                    <td class="align-middle text-danger">@item.Price.ToString("N0") đ</td>
                    <td class="align-middle"><span class="badge bg-success">@item.Status</span></td>
                    <td class="align-middle text-center">
                        <a class="btn btn-sm btn-warning" asp-page="./Edit" asp-route-id="@item.ProductId">Sửa</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <nav>
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= Model.PagedProducts.TotalPages; i++)
            {
                <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                    <a class="page-link" asp-route-PageNumber="@i"
                       asp-route-Name="@Model.Name"
                       asp-route-CategoryName="@Model.CategoryName"
                       asp-route-SortOrder="@Model.SortOrder">@i</a>
                </li>
            }
        </ul>
    </nav>
</div>