@page
@model MacVilla_Web.Pages.Admin.Users.CreateModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Tạo tài khoản - MacVilla</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        :root {
            --mv-green-dark: #7DA100;
        }

        body {
            background-color: #f4f6f9;
            font-family: 'Segoe UI', Tahoma, sans-serif;
            margin: 0;
        }

        .admin-header {
            background-color: var(--mv-green-dark);
            height: 65px;
            position: fixed;
            width: 100%;
            top: 0;
            z-index: 1050;
            padding: 0 30px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        .admin-wrapper {
            margin-top: 65px;
            padding: 40px 20%;
            min-height: calc(100vh - 115px);
        }

        .card-custom {
            border: none;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 0.5rem 1rem rgba(0,0,0,0.08);
        }

        .card-header-mv {
            background-color: var(--mv-green-dark);
            color: #fff;
            font-weight: bold;
            text-transform: uppercase;
            padding: 1.2rem;
        }

        .btn-mv-primary {
            background-color: var(--mv-green-dark);
            color: white;
            border: none;
            padding: 10px 30px;
            font-weight: 600;
        }

            .btn-mv-primary:hover {
                background-color: #6a8900;
                color: white;
            }

        .admin-footer {
            background-color: var(--mv-green-dark);
            color: #fff;
            padding: 15px 15%;
            font-size: 13px;
        }

        .form-control:focus, .form-select:focus {
            border-color: var(--mv-green-dark);
            box-shadow: 0 0 0 0.25rem rgba(125,161,0,0.1);
        }
    </style>
</head>
<body>
    <header class="admin-header d-flex align-items-center justify-content-between">
        <div class="d-flex align-items-center">
            <img src="~/Image/Logo/logo-macvilla.png" alt="MacVilla" style="height: 35px;" class="me-3">
            <span class="text-white fw-bold border-start ps-3 small text-uppercase">Tạo tài khoản mới</span>
        </div>
        <div class="dropdown">
            <button class="btn btn-link text-white text-decoration-none dropdown-toggle" data-bs-toggle="dropdown">
                <i class="bi bi-person-circle me-1"></i> Admin MacVilla
            </button>
            <ul class="dropdown-menu dropdown-menu-end border-0 shadow">
                <li><a class="dropdown-item py-2 text-danger" asp-page="/Auth/Logout"><i class="bi bi-box-arrow-right me-2"></i> Đăng xuất</a></li>
            </ul>
        </div>
    </header>

    <main class="admin-wrapper">
        <nav aria-label="breadcrumb" class="mb-4">
            <ol class="breadcrumb small">
                <li class="breadcrumb-item"><a asp-page="./Index" class="text-decoration-none" style="color: var(--mv-green-dark)">Người dùng</a></li>
                <li class="breadcrumb-item active">Tạo tài khoản mới</li>
            </ol>
        </nav>

        <div class="card card-custom">
            <div class="card-header card-header-mv text-center">
                <i class="bi bi-person-plus me-2"></i> TẠO TÀI KHOẢN MỚI
            </div>
            <div class="card-body p-4 p-lg-5">
                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="alert alert-danger"><i class="bi bi-exclamation-triangle me-2"></i>@Model.ErrorMessage</div>
                }

                <form method="post">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">HỌ TÊN <span class="text-danger">*</span></label>
                            <input asp-for="CreateRequest.FullName" class="form-control form-control-lg" placeholder="Nguyễn Văn A" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">EMAIL <span class="text-danger">*</span></label>
                            <input asp-for="CreateRequest.Email" type="email" class="form-control form-control-lg" placeholder="email@example.com" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">MẬT KHẨU <span class="text-danger">*</span></label>
                            <input asp-for="CreateRequest.Password" type="password" class="form-control form-control-lg" placeholder="Ít nhất 6 ký tự" required minlength="6" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">SỐ ĐIỆN THOẠI</label>
                            <input asp-for="CreateRequest.Phone" class="form-control form-control-lg" placeholder="0901234567" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">VAI TRÒ</label>
                            <select asp-for="CreateRequest.Role" class="form-select form-select-lg">
                                <option value="Customer">Customer</option>
                                <option value="Employee">Employee</option>
                                <option value="Admin">Admin</option>
                            </select>
                        </div>
                    </div>

                    <div class="mt-5 pt-4 border-top d-flex gap-2">
                        <button type="submit" class="btn btn-mv-primary shadow">
                            <i class="bi bi-check2-circle me-2"></i> TẠO TÀI KHOẢN
                        </button>
                        <a asp-page="./Index" class="btn btn-outline-secondary px-4 fw-bold">HỦY BỎ</a>
                    </div>
                </form>
            </div>
        </div>
    </main>

    <footer class="admin-footer d-flex justify-content-between mt-5">
        <div>&copy; 2026 <strong>MACVILLA</strong>. CMS System.</div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
