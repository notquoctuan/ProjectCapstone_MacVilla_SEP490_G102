@page
@model MacVilla_Web.Pages.Auth.LoginModel
@{
    ViewData["Title"] = "Đăng nhập - MacVilla";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        html, body {
            height: 100%;
            margin: 0;
            overflow: hidden;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        /* 1. NỀN SLIDESHOW */
        .full-slideshow {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            z-index: -2;
            background-color: #f8f9fa; /* Nền sáng dự phòng */
        }

        .overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            /* Giảm độ tối overlay để ảnh trông sáng hơn (0.2 thay vì 0.4) */
            background: rgba(0, 0, 0, 0.2);
            z-index: -1;
        }

        .slide-img {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-size: cover;
            background-position: center;
            opacity: 0;
            z-index: 1;
            transition: opacity 2s ease-in-out, transform 8s linear;
            transform: scale(1);
        }

            .slide-img.active {
                opacity: 1;
                z-index: 3;
                transform: scale(1.1);
            }

            .slide-img.last-active {
                opacity: 1;
                z-index: 2;
            }

        /* 2. LOGO TRANG CHỦ */
        .logo-home {
            position: absolute;
            top: 30px;
            left: 50px;
            z-index: 1001;
            background: none !important;
            border: none !important;
        }

            .logo-home img {
                height: 60px;
                width: auto;
                background-color: transparent !important;
                filter: drop-shadow(0 4px 6px rgba(0,0,0,0.3));
            }

        /* 3. NỘI DUNG CHÍNH */
        .main-content {
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .login-container {
            width: 100%;
            max-width: 1150px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 20px;
        }

        .brand-section {
            flex: 1.2;
            padding-right: 80px;
            color: white;
            text-shadow: 2px 4px 12px rgba(0,0,0,0.6); /* Tăng shadow để chữ nổi trên nền sáng */
        }

            .brand-section h1 {
                font-size: 5.5rem;
                font-weight: 800;
                margin-bottom: 10px;
            }

            .brand-section p {
                font-size: 2.2rem;
                font-weight: 600;
                color: #90EE90;
            }

        .login-card {
            background: rgba(255, 255, 255, 0.95); /* Thêm chút trong suốt cho card thêm sang */
            padding: 45px 40px;
            border-radius: 12px;
            width: 420px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.3);
        }

            .login-card .form-control {
                background-color: #ffffff !important;
                color: #000000 !important;
                border: 1px solid #ddd;
                height: 45px;
            }

        .btn-custom {
            background-color: #cc0000;
            color: white;
            font-weight: bold;
            padding: 12px;
            border: none;
            transition: 0.3s;
        }

            .btn-custom:hover {
                background-color: #a30000;
                color: white;
            }

        .btn-google-custom {
            border: 1px solid #28a745;
            color: #28a745;
            background: transparent;
            font-size: 0.9rem;
            transition: all 0.3s ease;
            padding: 10px;
        }

            .btn-google-custom:hover {
                background-color: #28a745 !important;
                color: white !important;
            }

        .link-signup {
            color: #28a745 !important;
            font-weight: bold;
            text-decoration: none;
        }

        .divider {
            border-top: 1px solid #eee;
            text-align: center;
            margin: 25px 0;
            position: relative;
        }

            .divider span {
                background: #fff;
                padding: 0 15px;
                color: #999;
                font-size: 0.8rem;
                position: relative;
                top: -12px;
            }
    </style>
</head>
<body>

    <a href="/" class="logo-home">
        <img src="~/Image/Logo/logo-macvilla.png" alt="MacVilla Logo" />
    </a>

    <div class="full-slideshow">
        <div class="slide-img active" style="background-image: url('https://images.unsplash.com/photo-1552321554-5fefe8c9ef14?q=80&w=2070')"></div>
        <div class="slide-img" style="background-image: url('https://images.unsplash.com/photo-1556911220-e15b29be8c8f?q=80&w=2070')"></div>
        <div class="slide-img" style="background-image: url('https://images.unsplash.com/photo-1620626011761-9963d7521576?q=80&w=2070')"></div>
        <div class="slide-img" style="background-image: url('https://images.unsplash.com/photo-1584622650111-993a426fbf0a?q=80&w=2070')"></div>
        <div class="slide-img" style="background-image: url('https://images.unsplash.com/photo-1484154218962-a197022b5858?q=80&w=2070')"></div>
        <div class="slide-img" style="background-image: url('https://images.unsplash.com/photo-1507652313519-d4e9174996dd?q=80&w=2070')"></div>
    </div>

    <div class="overlay"></div>

    <div class="main-content">
        <div class="login-container">
            <div class="brand-section d-none d-md-block">
                <h1>MacVilla</h1>
                <p>Giải pháp thiết bị vệ sinh <br> & nhà bếp hàng đầu Việt Nam</p>
            </div>

            <div class="login-card">
                <h3 class="text-center mb-4" style="color: #cc0000; font-weight: bold; letter-spacing: 1px;">ĐĂNG NHẬP</h3>

                <form method="post">
                    <div class="mb-3">
                        <input asp-for="Input.Email" class="form-control" placeholder="Email của bạn" />
                    </div>
                    <div class="mb-4">
                        <input asp-for="Input.Password" type="password" class="form-control" placeholder="Mật khẩu" />
                    </div>

                    <button type="submit" class="btn btn-custom w-100 shadow-sm">ĐĂNG NHẬP</button>

                    <div class="text-center mt-3">
                        <a href="#" style="color: #666; text-decoration: none; font-size: 0.9rem;">Quên mật khẩu?</a>
                    </div>

                    <div class="divider"><span>HOẶC</span></div>

                    <button type="button" class="btn btn-google-custom w-100 mb-3">
                        <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg" width="18" class="me-2">
                        Tiếp tục với Google
                    </button>

                    <div class="text-center mt-4" style="font-size: 0.85rem; color: #555;">
                        Bạn chưa có tài khoản? <a href="#" class="link-signup">Đăng ký ngay</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        const slides = document.querySelectorAll('.slide-img');
        let currentSlide = 0;

        function nextSlide() {
            if (slides.length < 2) return;
            const oldSlide = slides[currentSlide];
            currentSlide = (currentSlide + 1) % slides.length;
            const newSlide = slides[currentSlide];

            slides.forEach(s => s.classList.remove('last-active'));
            oldSlide.classList.remove('active');
            oldSlide.classList.add('last-active');
            newSlide.classList.add('active');
        }

        // Đổi ảnh sau mỗi 4 giây để trải nghiệm mượt mà hơn với nhiều ảnh
        setInterval(nextSlide, 4000);
    </script>
</body>
</html>