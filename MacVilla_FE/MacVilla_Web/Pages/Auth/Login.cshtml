@page "/Auth/Login"
@model MacVilla_Web.Pages.Auth.LoginModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - MacVilla Admin</title>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Be Vietnam Pro', sans-serif;
            min-height: 100vh;
            display: flex;
            background: linear-gradient(135deg, #1B5E20 0%, #2E7D32 40%, #388E3C 100%);
        }

        .login-left {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 40px;
            color: #fff;
        }

            .login-left h1 {
                font-size: 2.8rem;
                font-weight: 700;
                letter-spacing: -1px;
            }

            .login-left p {
                font-size: 1rem;
                opacity: .75;
                margin-top: 10px;
                max-width: 320px;
                text-align: center;
            }

        .login-icon {
            font-size: 5rem;
            margin-bottom: 20px;
            opacity: .9;
        }

        .login-right {
            width: 480px;
            background: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 60px 48px;
        }

        .login-form {
            width: 100%;
        }

            .login-form h2 {
                font-size: 1.5rem;
                font-weight: 700;
                color: #1a1a2e;
                margin-bottom: 6px;
            }

            .login-form .subtitle {
                color: #6b7280;
                font-size: .875rem;
                margin-bottom: 32px;
            }

        .form-group {
            margin-bottom: 18px;
        }

            .form-group label {
                display: block;
                font-size: .8rem;
                font-weight: 600;
                color: #374151;
                margin-bottom: 6px;
            }

            .form-group input {
                width: 100%;
                padding: 11px 14px;
                border: 1.5px solid #e5e7eb;
                border-radius: 8px;
                font-size: .9rem;
                font-family: inherit;
                transition: border-color .15s, box-shadow .15s;
                background: #fafafa;
            }

                .form-group input:focus {
                    outline: none;
                    border-color: #4CAF50;
                    box-shadow: 0 0 0 3px rgba(76,175,80,.12);
                    background: #fff;
                }

        .btn-login {
            width: 100%;
            padding: 12px;
            background: #2E7D32;
            color: #fff;
            border: none;
            border-radius: 8px;
            font-size: .95rem;
            font-weight: 600;
            cursor: pointer;
            transition: background .2s;
            font-family: inherit;
            margin-top: 8px;
        }

            .btn-login:hover {
                background: #1B5E20;
            }

            .btn-login:disabled {
                background: #9e9e9e;
                cursor: not-allowed;
            }

        .error-box {
            background: #fef2f2;
            border: 1px solid #fecaca;
            border-radius: 8px;
            padding: 12px 14px;
            font-size: .85rem;
            color: #dc2626;
            margin-bottom: 16px;
            display: none;
        }

            .error-box.show {
                display: block;
            }

        .input-wrap {
            position: relative;
        }

            .input-wrap .eye-btn {
                position: absolute;
                right: 12px;
                top: 50%;
                transform: translateY(-50%);
                background: none;
                border: none;
                cursor: pointer;
                color: #9ca3af;
                font-size: 1rem;
            }

        @@media (max-width: 768px) {
            .login-left {
                display: none;
            }

            .login-right {
                width: 100%;
                padding: 40px 24px;
            }
        }
    </style>
</head>
<body>
    <div class="login-left">
        <div class="login-icon">🌿</div>
        <h1>MacVilla</h1>
        <p>Hệ thống quản trị thương mại điện tử — quản lý sản phẩm, đơn hàng, khách hàng và danh mục.</p>
    </div>
    <div class="login-right">
        <div class="login-form">
            <h2>Chào mừng trở lại</h2>
            <p class="subtitle">Đăng nhập để truy cập bảng điều khiển</p>
            <div class="error-box" id="errBox"></div>
            <div class="form-group">
                <label>Email</label>
                <input type="email" id="email" placeholder="admin@macvilla.vn" autocomplete="email" />
            </div>
            <div class="form-group">
                <label>Mật khẩu</label>
                <div class="input-wrap">
                    <input type="password" id="password" placeholder="••••••••" autocomplete="current-password" />
                    <button class="eye-btn" onclick="togglePwd()" type="button" id="eyeBtn">👁</button>
                </div>
            </div>
            <button class="btn-login" id="loginBtn" onclick="doLogin()">Đăng nhập</button>
        </div>
    </div>

    <script>
        // Lấy CSRF token từ antiforgery (cần cho POST handler)
        function togglePwd() {
            const inp = document.getElementById('password');
            inp.type = inp.type === 'password' ? 'text' : 'password';
        }
        document.addEventListener('keydown', e => { if (e.key === 'Enter') doLogin(); });

        async function doLogin() {
            const email = document.getElementById('email').value.trim();
            const password = document.getElementById('password').value;
            const btn = document.getElementById('loginBtn');
            const errBox = document.getElementById('errBox');
            errBox.classList.remove('show');

            if (!email || !password) {
                errBox.textContent = 'Vui lòng nhập đầy đủ email và mật khẩu.';
                errBox.classList.add('show');
                return;
            }

            btn.disabled = true;
            btn.textContent = 'Đang đăng nhập...';

            try {
                // 1. Gọi BE để lấy JWT
                const res = await fetch('https://localhost:7262/api/auth/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email, password })
                });
                const data = await res.json();

                if (!res.ok) {
                    errBox.textContent = data.message || 'Tài khoản hoặc mật khẩu không chính xác.';
                    errBox.classList.add('show');
                    return;
                }

                // BE trả về AccessToken (không phải Token)
                const token = data.AccessToken;
                if (!token) {
                    errBox.textContent = 'Phản hồi không hợp lệ từ máy chủ.';
                    errBox.classList.add('show');
                    return;
                }

                // 2. Lưu vào sessionStorage để JS các trang khác dùng
                sessionStorage.setItem('jwt', token);
                sessionStorage.setItem('userName', data.FullName || data.Email || '');
                sessionStorage.setItem('userRole', data.Role || '');

                // 3. Lưu cookie để server-side Razor có thể đọc
                document.cookie = `jwt=${token}; path=/; SameSite=Strict`;

                // 4. Gọi server để set HttpContext.Session (cho server-side pages)
                await fetch('/Auth/Login?handler=SetSession', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ token: token, role: data.Role, name: data.FullName })
                });

                // 5. Redirect vào Dashboard
                window.location.href = '/Admin/Dashboard';

            } catch (e) {
                errBox.textContent = 'Không kết nối được máy chủ. Kiểm tra lại backend (https://localhost:7262).';
                errBox.classList.add('show');
            } finally {
                btn.disabled = false;
                btn.textContent = 'Đăng nhập';
            }
        }
    </script>
</body>
</html>
