@page
@model MacVilla_Web.Pages.Auth.LoginModel
@{
    ViewData["Title"] = "MacVilla";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-4 shadow p-4 border rounded bg-light">
            <h3 class="text-center mb-4">ĐĂNG NHẬP</h3>
            <form method="post">
                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input asp-for="Input.Email" class="form-control" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Mật khẩu</label>
                    <input asp-for="Input.Password" type="password" class="form-control" />
                </div>

                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="alert alert-danger py-2">@Model.ErrorMessage</div>
                }

                <button type="submit" class="btn btn-primary w-100">Đăng nhập</button>
            </form>
        </div>
    </div>
</div>