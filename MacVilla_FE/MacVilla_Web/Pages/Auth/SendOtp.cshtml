@page
@model MacVilla_Web.Pages.Auth.SendOtpModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Xác minh OTP - MacVilla</title>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Be Vietnam Pro', sans-serif;
            height: 100vh;
            display: flex;
            background: linear-gradient(135deg, #1B5E20, #388E3C);
            align-items: center;
            justify-content: center;
        }

        .card {
            width: 380px;
            background: #fff;
            border-radius: 16px;
            padding: 32px 28px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.15);
        }

        .title {
            font-size: 1.4rem;
            font-weight: 700;
            margin-bottom: 6px;
            color: #1a1a2e;
        }

        .subtitle {
            font-size: 0.85rem;
            color: #6b7280;
            margin-bottom: 20px;
        }

        .form-group {
            margin-bottom: 14px;
        }

        input {
            width: 100%;
            padding: 11px 14px;
            border-radius: 8px;
            border: 1.5px solid #e5e7eb;
            font-size: 0.9rem;
            background: #fafafa;
        }

            input:focus {
                outline: none;
                border-color: #4CAF50;
                background: #fff;
                box-shadow: 0 0 0 3px rgba(76,175,80,.12);
            }

        .btn {
            width: 100%;
            padding: 11px;
            border-radius: 8px;
            border: none;
            font-weight: 600;
            cursor: pointer;
            margin-top: 10px;
        }

        .btn-send {
            background: #2E7D32;
            color: #fff;
        }

            .btn-send:hover {
                background: #1B5E20;
            }

            .btn-send:disabled {
                background: #9e9e9e;
                cursor: not-allowed;
            }

        .msg {
            margin-top: 12px;
            font-size: 0.85rem;
        }

        .error {
            color: #dc2626;
        }

        .success {
            color: #16a34a;
        }

        .back {
            margin-top: 16px;
            text-align: center;
        }

            .back a {
                font-size: 0.85rem;
                color: #2E7D32;
                text-decoration: none;
                font-weight: 500;
            }

                .back a:hover {
                    text-decoration: underline;
                }
    </style>
</head>

<body>
    <div class="card">
        <div class="title">Xác minh OTP</div>
        <div class="subtitle">Nhập email để nhận mã OTP và tiếp tục</div>

        <!-- SEND OTP -->
        <form method="post" asp-page-handler="SendOtp" id="otpForm">
            <div class="form-group">
                <input asp-for="Email" placeholder="Nhập email của bạn" />
            </div>
            <button class="btn btn-send" type="submit" id="sendBtn">
                Gửi OTP
            </button>
        </form>

        @if (Model.Message != null)
        {
            <div class="msg @(Model.IsError ? "error" : "success")">
                @Model.Message
            </div>
        }

        <!-- BACK -->
        <div class="back">
            <a href="/Auth/Login">← Quay lại đăng nhập</a>
        </div>
    </div>

    <script>
        // loading khi bấm gửi
        document.getElementById("otpForm").addEventListener("submit", function () {
            const btn = document.getElementById("sendBtn");
            btn.disabled = true;
            btn.innerText = "Đang gửi...";
        });
    </script>
</body>
</html>