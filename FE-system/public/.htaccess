# SPA (Vite + React Router): on hard refresh, serve index.html for non-file URLs.
# Copied to dist/ by `npm run build`. Upload dist including this file.
#
# Subfolder deploy (e.g. https://example.com/app/): set Vite `base: '/app/'`, then
# RewriteBase /app/ and RewriteRule . /app/index.html [L]

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
