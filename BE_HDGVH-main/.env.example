# Sao chép thành .env và đổi giá trị.
# - Docker Compose: substitution ${VAR} khi chạy compose.
# - dotnet run (không Docker): Program.cs gọi DotEnvLoader — đọc .env từ thư mục làm việc (thường là thư mục project chứa .csproj).

# --- SQL Server (mật khẩu phức tạp: chữ hoa, thường, số, ký tự đặc biệt) ---
MSSQL_SA_PASSWORD=YourStrong@Passw0rd

# --- ASP.NET (production mặc định trong docker-compose; dev local có thể đặt Development) ---
# ASPNETCORE_ENVIRONMENT=Development

# --- payOS (production Docker — map vào PayOs__* + PAYOS_* trong container) ---
# https://payos.vn/docs/api/
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
# URL frontend sau thanh toán / hủy (phải là URL công khai khi payOS gọi redirect)
PAYOS_RETURN_URL=https://example.com/store/checkout/return
PAYOS_CANCEL_URL=https://example.com/store/checkout/cancel
# Tuỳ chọn
# PAYOS_PARTNER_CODE=
# PAYOS_LINK_LIFETIME_MINUTES=1440

# --- Cloudinary (upload admin) ---
# Tên CLOUDINARY_* (giống docker-compose) được tự map sang Cloudinary__* trước khi app đọc cấu hình.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# CLOUDINARY_BASE_FOLDER=admin
# CLOUDINARY_MAX_FILE_BYTES=15728640
# Hoặc ghi trực tiếp: Cloudinary__CloudName= ...

# --- JWT production: thêm vào service api, ví dụ Jwt__Key: ${JWT_KEY} (không dùng giá trị rỗng — sẽ ghi đè appsettings) ---
